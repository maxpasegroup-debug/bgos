# Copy to .env.local or .env (never commit real secrets).

# Railway Postgres: Project → Postgres → Variables → DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Required in production: strong random secret, min 32 characters (HS256).
# JWT_SECRET=""

# Optional: shown on Basic plan as “Email sales” for Pro / Sales Booster upgrades.
# NEXT_PUBLIC_BGOS_UPGRADE_EMAIL="sales@yourcompany.com"

# Plan lock: force BASIC behavior (hide Sales Booster / upgrade UI, no WhatsApp automation).
# true|1|on = always lock; false|0|off = never lock; unset = lock when NODE_ENV=production.
# BGOS_PLAN_LOCK_BASIC="false"

# --- Razorpay (Indian billing) — server + public key ID only on client
# RAZORPAY_KEY_ID=rzp_live_xxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxx
# Webhook body HMAC: prefer Dashboard → Webhooks secret; else KEY_SECRET is used as fallback.
# RAZORPAY_WEBHOOK_SECRET=xxxxxxxx
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxx

# --- Stripe (optional; used when NEXT_PUBLIC_RAZORPAY_KEY_ID is unset for Pro checkout)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ENTERPRISE=
