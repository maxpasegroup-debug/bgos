  @@index([assignedRsmId, status, createdAt])
  @@index([assignedBdmId, status, createdAt])
  @@index([assignedBdeId, status, createdAt])
  @@map("onboarding_pipeline")
}

/**
 * Sales-launch referral partner registry (cross-company).
 */

/**
