// BGOS + ICECONNECT — multi-company schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES_HEAD
  SALES_EXECUTIVE
  /**
   * Field sales / dialling — same workspace capabilities as sales executive.
   */
  TELECALLER
  /**
   * BGOS Internal tech lead (delivery pipeline).
   */
  TECH_HEAD
  /**
   * BGOS Internal tech execution (delivery pipeline).
   */
  TECH_EXECUTIVE
  CHANNEL_PARTNER
  OPERATIONS_HEAD
  SITE_ENGINEER
  PRO
  INSTALLATION_TEAM
  SERVICE_TEAM
  INVENTORY_MANAGER
  ACCOUNTANT
  LCO
  HR_MANAGER
  /**
   * Online micro-franchise partner (ICECONNECT workspace, referral + wallet).
   */
  MICRO_FRANCHISE
}

/// Which product surface this user belongs to (ICECONNECT = field / solar workforce app).
enum EmployeeSystem {
  BGOS
  ICECONNECT
}

/// Business domain for data flow to BGOS Boss (brain vs solar install base).
enum EmployeeDomain {
  BGOS
  SOLAR
}

/// ICECONNECT mobile hierarchy role (orthogonal to {@link UserRole} jobRole).
enum IceconnectEmployeeRole {
  RSM
  BDM
  BDE
  TECH_EXEC
}

enum CompanyPlan {
  BASIC
  PRO
  ENTERPRISE
}

/**
 * Derived billing/trial state; kept in sync on writes and subscription reads.
 */
enum CompanySubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  /**
   * Custom-build workspaces: selected plan but initial subscription payment not completed yet.
   */
  PAYMENT_PENDING
}

enum CompanyIndustry {
  SOLAR
  CUSTOM
}

/**
 * Product line: solar CRM vs paid custom dashboard build.
 */
enum CompanyBusinessType {
  SOLAR
  CUSTOM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  SITE_VISIT_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  /**
   * Quotation approved — booked, awaiting payment.
   */
  PROPOSAL_WON
  WON
  LOST
}

enum LeadResponseStatus {
  RESPONSIVE
  SILENT
  COOLING
}

/**
 * BGOS Internal sales metro pipeline (company with `internalSalesOrg`). Linear order — no skips.
 */
enum InternalSalesStage {
  LEAD_ADDED
  INTRO_CALL
  DEMO_ORIENTATION
  FOLLOW_UP
  INTERESTED
  ONBOARDING_FORM_FILLED
  BOSS_APPROVAL_PENDING
  SENT_TO_TECH
  TECH_READY
  DELIVERED
  CLIENT_LIVE
  CLOSED_LOST
}

/**
 * Tech delivery metro (after Sent to Tech).
 */
enum InternalTechStage {
  ONBOARDING_RECEIVED
  DATA_VERIFIED
  DASHBOARD_SETUP
  EMPLOYEE_SETUP
  SYSTEM_TESTING
  READY_FOR_DELIVERY
}

enum InternalOnboardingApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InternalCallStatus {
  NOT_CALLED
  CALLED
  NO_ANSWER
  INTERESTED
  NOT_INTERESTED
}

/**
 * ICECONNECT sales executive metro pipeline (internal org). SUBSCRIPTION = converted customer.
 */
enum IceconnectMetroStage {
  LEAD_CREATED
  INTRO_CALL
  DEMO_DONE
  FOLLOW_UP
  ONBOARDING
  PAYMENT_DONE
  SUBSCRIPTION
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
}

/**
 * Plan tier for executive targets and converted ICECONNECT customers.
 */
enum IceconnectCustomerPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

/**
 * Category for a single active user manual PDF per company.
 */
enum UserManualCategory {
  SALES
  OPERATIONS
  HR
  ACCOUNTS
  SALES_BOOSTER
}

/**
 * Internal CRM: onboarding tier chosen by sales before the client form opens.
 */
enum LeadOnboardingType {
  BASIC
  PRO
  ENTERPRISE
}

/**
 * Tech queue sort: Enterprise first, then Pro, then Basic.
 */
enum TechQueuePriority {
  CRITICAL
  HIGH
  LOW
}

/**
 * Tech delivery steps (no skipping). Synced to {@link InternalTechStage} on the lead when possible.
 */
enum TechPipelineStage {
  RECEIVED
  SETUP_DASHBOARD
  ADD_EMPLOYEES
  CONFIGURE_MODULES
  TESTING
  READY
}

/**
 * Tech onboarding queue for internal sales → delivery.
 */
enum OnboardingTaskStatus {
  NEW
  DATA_RECEIVED
  SETUP_STARTED
  SETUP_COMPLETED
  DELIVERED
}

enum DealStatus {
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum PaymentStatus {
  PAID
  PENDING
}

enum ServiceTicketStatus {
  OPEN
  RESOLVED
}

/**
 * BGOS onboarding workflow templates (category + tier).
 */
enum OnboardingWorkflowPlanTier {
  BASIC
  PRO
  ENTERPRISE
}

enum OnboardingSubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_INFO
  READY
  DELIVERED
}

enum OnboardingTechTaskStatus {
  NEW
  IN_PROGRESS
  WAITING_INFO
  READY
  DELIVERED
}

model Company {
  id           String              @id @default(cuid())
  name         String
  industry     CompanyIndustry     @default(SOLAR)
  /**
   * Solar (default trial path) vs custom paid build — see {@link CompanyBusinessType}.
   */
  businessType CompanyBusinessType @default(SOLAR)
  /**
   * Subscription tier; remains {@link CompanyPlan} in DB (not a free-form string).
   */
  plan         CompanyPlan         @default(BASIC)
  ownerId      String
  /// Tenant routing: SOLAR (solar boss) vs BGOS (default brain).
  workspaceDomain EmployeeDomain @default(SOLAR)
  /// Onboarding dashboard template (solar, builder, academy, custom).
  dashboardTemplate OnboardingRequestDashboardType @default(SOLAR)
  createdAt    DateTime            @default(now())

  /**
   * Clock start for the 15-day BASIC trial; null = pre-trial schema / grandfathered.
   */
  trialStartDate DateTime?
  /**
   * Exclusive wall-clock end: expired when `now >= trialEndDate` for BASIC.
   */
  trialEndDate   DateTime?
  isTrialActive  Boolean   @default(true)

  /**
   * Subscription status (trial / active paid / expired trial).
   * Canonical plan tier remains {@link CompanyPlan} in `plan`. Trial end instant remains `trialEndDate`
   * (APIs may expose it as `trialEndsAt`).
   */
  subscriptionStatus      CompanySubscriptionStatus @default(TRIAL)
  /**
   * Wall-clock start of the current paid Razorpay/Stripe period (optional).
   */
  subscriptionPeriodStart DateTime?
  /**
   * Paid access valid strictly before this instant (Razorpay monthly renewals extend this).
   */
  subscriptionPeriodEnd   DateTime?

  logoUrl        String?
  primaryColor   String?
  secondaryColor String?

  /**
   * Public / document-facing profile (quotations, invoices, PDFs).
   */
  companyEmail   String?
  companyPhone   String?
  billingAddress String? @db.Text
  gstNumber      String?
  bankDetails    String? @db.Text

  businessTemplate String?
  dashboardConfig  Json?

  /**
   * True for the dedicated BGOS internal sales tenant (“BGOS Internal”).
   */
  internalSalesOrg               Boolean @default(false)
  /**
   * Optional default assignee for public / anonymous lead capture.
   */
  internalSalesDefaultAssigneeId String?
  /**
   * Round-robin: last tech user id assigned to an onboarding workflow submission.
   */
  internalWorkflowLastTechUserId String?

  /**
   * Set when the customer completes the custom requirements form (custom businessType only).
   */
  customOnboardingSubmittedAt     DateTime?
  /**
   * After internal sales confirms final payment, tech may contact the client and start build.
   * Until then: internal planning only (no client comms).
   */
  customBuildClientContactAllowed Boolean   @default(false)
  customFinalPaymentConfirmedAt   DateTime?

  /**
   * Platform (super boss): hide archived tenants from the client directory.
   */
  archivedAt              DateTime?
  /**
   * Optional referral phone captured at launch.
   */
  referralPhone           String?
  /**
   * Sales-launch channel partner (cross-company referral tracking).
   */
  launchChannelPartnerId  String?
  /**
   * Micro-franchise partner linked by referral phone (takes precedence over channel partner when matched).
   */
  microFranchisePartnerId String?

  /**
   * Acquisition channel for Nexa / CRM attribution: direct, sales, franchise.
   */
  sourceType String? @map("source_type")
  /**
   * Stable id for attribution (e.g. internal lead id, franchise partner id).
   */
  sourceId   String? @map("source_id")

  owner                        User                              @relation("OwnedCompany", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships                  UserCompany[]
  leads                        Lead[]
  deals                        Deal[]
  tasks                        Task[]
  installations                Installation[]
  projects                     Project[]
  payments                     Payment[]
  quotations                   Quotation[]
  moneyInvoices                Invoice[]
  expenses                     Expense[]
  invoicePayments              InvoicePayment[]
  activityLogs                 ActivityLog[]
  serviceTickets               ServiceTicket[]
  serviceJobs                  ServiceJob[]
  automations                  Automation[]
  nexaActions                  NexaAction[]
  documents                    Document[]
  leaveRequests                LeaveRequest[]
  attendances                  Attendance[]
  salaries                     Salary[]
  products                     Product[]
  inventoryItems               InventoryItem[]
  stocks                       Stock[]
  stockLogs                    StockLog[]
  channelPartners              ChannelPartner[]
  commissions                  Commission[]
  siteVisits                   SiteVisit[]
  approvals                    Approval[]
  growthPlan                   CompanyGrowthPlan?
  employeePips                 EmployeePip[]
  lcoLoans                     LcoLoan[]
  customerUsers                CustomerPortalUser[]
  complaints                   CustomerComplaint[]
  razorpayPayments             RazorpayPayment[]
  onboardingTasks              OnboardingTask[]
  internalLeadActivities       InternalLeadActivity[]
  internalInAppNotifications   InternalInAppNotification[]
  internalEmployeeDailyTargets InternalEmployeeDailyTarget[]
  internalNexaSupportTickets   InternalNexaSupportTicket[]
  userManuals                  UserManual[]
  salesExecutiveMonthlyTargets SalesExecutiveMonthlyTarget[]
  onboardingFormTemplates      OnboardingFormTemplate[]
  onboardingSubmissions        OnboardingSubmission[]
  onboardingSessions           OnboardingSession[]
  onboardingRecords            Onboarding[]
  onboardingPipeline           OnboardingPipeline[]
  ownershipClaims             OwnershipClaim[]
  launchChannelPartner         LaunchChannelPartner?             @relation("LaunchPartnerCompany", fields: [launchChannelPartnerId], references: [id], onDelete: SetNull)
  microFranchisePartner        MicroFranchisePartner?            @relation(fields: [microFranchisePartnerId], references: [id], onDelete: SetNull)
  microFranchiseCommissionTxs  CommissionTransaction[]
  techRequests                 TechRequest[]
  salesBoosterMessages         SalesBoosterOmnichannelMessage[]
  salesBoosterCampaigns        SalesBoosterOmnichannelCampaign[]
  salesBoosterConnections      SalesBoosterChannelConnection[]
  salesBoosterAutomationFlow   SalesBoosterAutomationFlow?
  performanceMetrics           PerformanceMetric[]
  salesNetworkTargets          SalesNetworkTarget[]
  networkCommissions           NetworkCommission[]
  promotionTrackers            PromotionTracker[]
  techQueueEntries             TechQueueEntry[]
  nexaTasks                    NexaTask[]
  techRoundRobinState          TechRoundRobinState?
  salesHierarchySubscriptions  SalesHierarchySubscription[]
  salesHierarchyEarnings       SalesHierarchyEarning[]
  nexaCoachingLogs             NexaCoachingLog[]
  nexaCompetitions             NexaCompetition[]
  nexaEmployeeWelfare          NexaEmployeeWelfare[]
  nexaAnnouncements            NexaAnnouncement[]
  nexaPersuasionStates         NexaPersuasionState[]
  /// Plan caps for users / leads / projects (solar boss scaling gate).
  companyLimit                 CompanyLimit?
  subscription                 Subscription?
  usageMetric                  UsageMetric?
  usageFlags                   UsageFlag[]
  usageCapacityNotifications   UsageCapacityNotification[]

  @@index([name])
  @@index([ownerId])
  @@index([launchChannelPartnerId])
  @@index([microFranchisePartnerId])
}

/// Enforces max users, leads, and projects per company (upgrade path when exceeded).
model CompanyLimit {
  id          String @id @default(cuid())
  companyId   String @unique
  maxUsers    Int    @default(12)
  maxLeads    Int    @default(300)
  maxProjects Int    @default(50)
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_limits")
}

/// Billing subscription snapshot per company (explicit payment layer table).
model Subscription {
  id        String                    @id @default(cuid())
  companyId String                    @unique
  plan      CompanyPlan
  status    CompanySubscriptionStatus
  expiry    DateTime
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

/// Cached tenant usage for capacity alerts (recalculated daily or on demand).
model UsageMetric {
  id              String   @id @default(cuid())
  companyId       String   @unique
  currentUsers    Int      @default(0)
  currentLeads    Int      @default(0)
  currentProjects Int      @default(0)
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("usage_metrics")
}

enum UsageFlagKind {
  USERS
  LEADS
  PROJECTS
}

enum UsageFlagStatus {
  ACTIVE
  IN_PROGRESS
  CONVERTED
  CLOSED
}

enum UsageCapacityNotificationStatus {
  UNREAD
  READ
}

/// High-usage (e.g. ≥80% of cap) capacity flag for sales follow-up.
model UsageFlag {
  id            String            @id @default(cuid())
  companyId     String
  kind          UsageFlagKind
  status        UsageFlagStatus   @default(ACTIVE)
  handledById   String?
  /// UI workflow: pending → contacted → closed (parallel to {@link status}).
  actionStatus  String            @default("pending")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  company       Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  handledBy     User?                       @relation("UsageFlagHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  notifications UsageCapacityNotification[]

  @@index([companyId, kind, status])
  @@index([companyId, status])
  @@map("usage_flags")
}

/// In-app alerts for ICECONNECT sales (RSM / BDM / BDE) when capacity flags fire.
model UsageCapacityNotification {
  id          String                          @id @default(cuid())
  companyId   String
  userId      String
  usageFlagId String?
  message     String                          @db.Text
  status      UsageCapacityNotificationStatus   @default(UNREAD)
  createdAt   DateTime                        @default(now())
  readAt      DateTime?

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageFlag UsageFlag? @relation(fields: [usageFlagId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([companyId])
  @@map("usage_capacity_notifications")
}

/**
 * Omnichannel Sales Booster — channel identifiers (UI + API).
 */
enum SalesBoosterOmnichannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
  SMS
}

enum SalesBoosterConnectionState {
  DISCONNECTED
  PENDING
  CONNECTED
}

enum SalesBoosterCampaignState {
  DRAFT
  SCHEDULED
  SENT
  PAUSED
}

/**
 * In-app omnichannel thread messages (company-scoped). Mapped to `sales_booster_messages`.
 */
model SalesBoosterOmnichannelMessage {
  id        String                  @id @default(cuid())
  companyId String
  channel   SalesBoosterOmnichannel
  sender    String
  content   String                  @db.Text
  leadId    String?
  createdAt DateTime                @default(now())
  readAt    DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt(sort: Desc)])
  @@map("sales_booster_messages")
}

model SalesBoosterOmnichannelCampaign {
  id             String                    @id @default(cuid())
  companyId      String
  channel        SalesBoosterOmnichannel
  status         SalesBoosterCampaignState @default(DRAFT)
  name           String?
  sentCount      Int                       @default(0)
  deliveredCount Int                       @default(0)
  responseCount  Int                       @default(0)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("sales_booster_campaigns")
}

model SalesBoosterChannelConnection {
  id          String                      @id @default(cuid())
  companyId   String
  channel     SalesBoosterOmnichannel
  status      SalesBoosterConnectionState @default(DISCONNECTED)
  credentials Json?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, channel])
  @@map("sales_booster_connections")
}

/**
 * Single automation flow JSON per company (chatbot builder).
 */
model SalesBoosterAutomationFlow {
  id               String   @id @default(cuid())
  companyId        String   @unique
  jsonFlow         Json
  autoReplyEnabled Boolean  @default(false)
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("sales_booster_automation_flows")
}

/**
 * Boss monthly targets on Home — drives projections (1Y / multi-year copy).
 */
model CompanyGrowthPlan {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  targetRevenueOneMonth Float    @default(0)
  targetLeadsOneMonth   Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/**
 * Performance improvement plan for an employee.
 */
model EmployeePip {
  id          String    @id @default(cuid())
  companyId   String
  userId      String
  goal        String    @db.Text
  progress    Int       @default(0)
  isCompleted Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, userId, isCompleted])
}

/**
 * Loan compliance tracker linked to customer lead.
 */
model LcoLoan {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  loanAmount Float
  /// PENDING | APPROVED | REJECTED
  status     String   @default("PENDING")
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/**
 * Customer login account for ICECONNECT customer portal (one per customer lead).
 */
model CustomerPortalUser {
  id           String   @id @default(cuid())
  companyId    String
  leadId       String   @unique
  mobile       String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, mobile])
  @@index([companyId])
  @@index([mobile])
}

/**
 * Customer complaints linked to a customer lead.
 */
model CustomerComplaint {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String
  description String   @db.Text
  /// PENDING | RESOLVED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Processed billing webhook deliveries (e.g. Stripe `evt_*`) — prevents double-applying upgrades.
model BillingWebhookEvent {
  id         String   @id @default(cuid())
  provider   String   @default("stripe")
  externalId String   @unique
  eventType  String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

/// Razorpay Checkout payments (verify path + idempotency).
model RazorpayPayment {
  id                String      @id @default(cuid())
  companyId         String
  userId            String
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique
  plan              CompanyPlan
  amount            Int
  currency          String      @default("INR")
  status            String
  pricingVersion    String      @default("v1.0")
  createdAt         DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

/// Membership: `role` is company-level (ADMIN vs EMPLOYEE); `jobRole` is operational RBAC (solar CRM role enum).
model UserCompany {
  id                String   @id @default(cuid())
  userId            String
  companyId         String
  role              String
  jobRole           UserRole
  dashboardAssigned String?
  /// READY | PENDING_BUILD | IN_PROGRESS | LIVE
  status            String   @default("READY")
  createdAt         DateTime @default(now())
  /**
   * Sales / HR network layer (BGOS Control v3) — optional; legacy rows stay null.
   */
  salesNetworkRole  SalesNetworkRole?
  /** Manager in the same company workspace (RSM → BDM → BDE chain). */
  parentUserId      String?
  /** RSM region label (e.g. South India). */
  region            String?
  archivedAt        DateTime?
  /// Sales hierarchy V1 — active customer subs counted for this member (see sales_subscriptions).
  activeSubscriptionsCount Int      @default(0)
  totalPoints              Int      @default(0)
  /// BDE: capped recurring; BDM+ false = full recurring (config-driven).
  recurringCap             Boolean  @default(true)
  /// BDM: max direct BDEs; raised by performance.
  bdeSlotLimit             Int      @default(0)
  createdByUserId          String?
  benefitLevel             SalesBenefitLevel @default(FULL)

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentUser User?   @relation("SalesNetworkParent", fields: [parentUserId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("MembershipCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@index([parentUserId])
  @@index([companyId, salesNetworkRole])
  @@index([createdByUserId])
  /// Compound index for paginated team roster queries ordered by join date.
  @@index([companyId, createdAt])
}

/** BGOS Control hybrid sales network role (orthogonal to {@link UserRole} jobRole). */
enum SalesNetworkRole {
  BOSS
  RSM
  BDM
  BDE
  TECH_EXEC
}

/// BDM benefit tier when active subscription count fluctuates (grace band).
enum SalesBenefitLevel {
  FULL
  GRACE
  REDUCED
}

/// Hierarchy subscription plan (sales engine — not company billing plan).
enum SalesHierarchyPlan {
  BASIC
  PRO
  CUSTOM
}

enum SalesHierarchySubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum NetworkCommissionType {
  DIRECT
  OVERRIDE
  RECURRING
}

/**
 * Payout lifecycle for each SalesHierarchyEarning row.
 *
 * PENDING  — earning written; not yet in a payout cycle.
 * APPROVED — monthly cycle has approved this batch; wallet approval pending.
 * PAID     — wallet transaction moved to withdrawable; cycle complete.
 *
 * Transition: PENDING → APPROVED → PAID (only via runMonthlyPayoutCycle).
 * Direct wallet manipulation is not permitted by the rules.
 */
enum EarningPayoutStatus {
  PENDING
  APPROVED
  PAID
}

enum TechQueueStatus {
  PENDING
  ASSIGNED
  DONE
  CANCELLED
}

enum NexaTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum NexaTaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// Monthly rollup for sales network performance (company-scoped).
model PerformanceMetric {
  id                   String   @id @default(cuid())
  companyId            String
  userId               String
  /// First day of month or yyyy-MM key — stored as yyyy-MM-01 for queries.
  month                DateTime
  totalSales           Float    @default(0)
  totalRevenue         Float    @default(0)
  newCustomers         Int      @default(0)
  bdeCreated           Int      @default(0)
  promotionsAchieved   Int      @default(0)
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, month])
  @@index([companyId])
  @@index([userId])
  @@map("performance_metrics")
}

/// Configurable targets per network role within a company.
model SalesNetworkTarget {
  id                        String           @id @default(cuid())
  companyId                 String
  role                      SalesNetworkRole
  monthlyRevenueTarget      Float            @default(0)
  monthlyCustomerTarget     Int              @default(0)
  bdeCreationTarget         Int              @default(0)
  consecutiveMonthsRequired Int              @default(3)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, role])
  @@index([companyId])
  @@map("sales_network_targets")
}

model NetworkCommission {
  id           String                @id @default(cuid())
  companyId    String
  userId       String
  sourceUserId String?
  amount       Float
  type         NetworkCommissionType
  createdAt    DateTime              @default(now())

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User    @relation("NetworkCommissionPayee", fields: [userId], references: [id], onDelete: Cascade)
  sourceUser User?   @relation("NetworkCommissionSource", fields: [sourceUserId], references: [id], onDelete: SetNull)

  @@index([companyId, userId])
  @@index([createdAt])
  @@map("network_commissions")
}

model PromotionTracker {
  id                     String   @id @default(cuid())
  companyId              String
  userId                 String
  currentStreak          Int      @default(0)
  targetMet              Boolean  @default(false)
  eligibleForPromotion   Boolean  @default(false)
  /// V1 engine: promotion path (BDM or RSM).
  roleTarget             SalesNetworkRole?
  activeCountSnapshot    Int?
  lastPromotionCheckAt   DateTime?
  updatedAt              DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  /// Standalone user index — for per-user promotion checks without a companyId filter.
  @@index([userId])
  @@map("promotion_tracker")
}

/// Customer subscription sale attributed to a hierarchy member (sales engine).
model SalesHierarchySubscription {
  id          String                         @id @default(cuid())
  companyId   String
  ownerUserId String
  planType    SalesHierarchyPlan
  points      Int                            @default(0)
  status      SalesHierarchySubscriptionStatus @default(ACTIVE)
  startedAt   DateTime                       @default(now())
  expiresAt   DateTime

  /// Optional client-side identifiers supplied at sale time — used for duplicate detection.
  clientEmail String?
  clientPhone String?

  /// Fraud guard (bgos_fraud_guard_v1): true when a duplicate-contact/email check fires.
  fraudFlagged  Boolean @default(false)
  /// Human-readable reason for the flag (e.g. "Duplicate email: a@b.com already sold by user X").
  fraudReason   String?

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  owner     User     @relation("SalesHierarchySubscriptionOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  earnings  SalesHierarchyEarning[]
  fraudLogs InternalFraudLog[]

  @@index([companyId, ownerUserId])
  /// Standalone owner index — used by per-BDE subscription lookups and batch counts.
  @@index([ownerUserId])
  @@index([status, expiresAt])
  @@index([clientEmail])
  @@index([clientPhone])
  @@map("sales_subscriptions")
}

model SalesHierarchyEarning {
  id             String                @id @default(cuid())
  companyId      String
  userId         String
  sourceUserId   String?
  subscriptionId String?
  amount         Float
  type           NetworkCommissionType
  /// Payout lifecycle: PENDING → APPROVED → PAID via monthly payout cycle.
  payoutStatus   EarningPayoutStatus   @default(PENDING)
  /// When this earning was moved to APPROVED in the payout cycle.
  approvedAt     DateTime?
  /// When this earning was fully paid out (wallet moved to withdrawable).
  paidAt         DateTime?
  createdAt      DateTime              @default(now())

  company      Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User                      @relation("SalesHierarchyEarningPayee", fields: [userId], references: [id], onDelete: Cascade)
  sourceUser   User?                     @relation("SalesHierarchyEarningSource", fields: [sourceUserId], references: [id], onDelete: SetNull)
  subscription SalesHierarchySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId, userId])
  /// Standalone user index — used by wallet/payout per-user earnings queries.
  @@index([userId])
  @@index([payoutStatus, createdAt])
  @@index([createdAt])
  @@map("sales_hierarchy_earnings")
}

model TechQueueEntry {
  id                 String          @id @default(cuid())
  companyId          String
  requestId          String
  assignedToUserId   String?
  status             TechQueueStatus @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([assignedToUserId])
  @@map("tech_queue")
}

model NexaTask {
  id        String         @id @default(cuid())
  companyId String
  userId    String
  task      String         @db.Text
  status    NexaTaskStatus @default(PENDING)
  priority  NexaTaskPriority @default(MEDIUM)
  dueDate   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, status])
  @@map("nexa_tasks")
}

/// Single row per company — cursor for tech_exec round-robin.
model TechRoundRobinState {
  companyId          String @id
  lastAssignedUserId String?
  position           Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("tech_round_robin_state")
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  /**
   * Globally unique login identity (boss, employees, ICECONNECT).
   */
  email                String    @unique
  password             String
  mobile               String?   @unique
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  /**
   * Set when the boss completes onboarding step 2 (NEXA activation). Invited employees get this on create.
   */
  workspaceActivatedAt DateTime?
  /**
   * Force one-time password reset on first successful login.
   */
  firstLogin           Boolean   @default(false)
  /**
   * Hard gate for credentials minted during onboarding/import.
   */
  forcePasswordReset   Boolean   @default(false)
  /**
   * Updated on every successful authentication.
   */
  lastLogin            DateTime?

  companiesOwned                    Company[]                     @relation("OwnedCompany")
  memberships                       UserCompany[]
  membershipsCreated                UserCompany[]                 @relation("MembershipCreatedBy")
  networkManagedMembers             UserCompany[]                 @relation("SalesNetworkParent")
  salesHierarchySubscriptionsOwned  SalesHierarchySubscription[]  @relation("SalesHierarchySubscriptionOwner")
  salesHierarchyEarningsReceived    SalesHierarchyEarning[]       @relation("SalesHierarchyEarningPayee")
  salesHierarchyEarningsAsSource    SalesHierarchyEarning[]       @relation("SalesHierarchyEarningSource")
  performanceMetrics                PerformanceMetric[]
  networkCommissionsReceived        NetworkCommission[]           @relation("NetworkCommissionPayee")
  networkCommissionsAsSource        NetworkCommission[]           @relation("NetworkCommissionSource")
  promotionTrackers                 PromotionTracker[]
  techQueueAssignments              TechQueueEntry[]
  nexaTasks                         NexaTask[]
  assignedLeads                     Lead[]                        @relation("LeadAssignee")
  leadsCreated                      Lead[]                        @relation("LeadCreator")
  leadsOwned                        Lead[]                        @relation("LeadOwner")
  leadsSourced                      Lead[]                        @relation("LeadSourceUser")
  tasks                             Task[]
  activityLogs                      ActivityLog[]
  assignedInstallations             Installation[]                @relation("InstallationAssignee")
  assignedServiceTickets            ServiceTicket[]               @relation("TicketAssignee")
  leaveRequests                     LeaveRequest[]
  attendances                       Attendance[]
  salaries                          Salary[]
  pips                              EmployeePip[]
  createdChannelPartners            ChannelPartner[]              @relation("PartnerCreator")
  assignedSiteVisits                SiteVisit[]                   @relation("SiteVisitAssignee")
  documentsUploaded                 Document[]
  razorpayPayments                  RazorpayPayment[]
  onboardingTasksCreated            OnboardingTask[]              @relation("OnboardingTaskCreator")
  internalLeadActivities            InternalLeadActivity[]
  internalInAppNotifications        InternalInAppNotification[]
  internalNexaSupportTicketsCreated InternalNexaSupportTicket[]   @relation("NexaSupportCreator")
  salesExecutiveMonthlyTargets      SalesExecutiveMonthlyTarget[]
  onboardingSubmissionsFilled       OnboardingSubmission[]        @relation("OnboardingFilledBy")
  onboardingSubmissionsTech         OnboardingSubmission[]        @relation("OnboardingTechAssignee")
  onboardingWorkflowMessages        OnboardingMessage[]
  onboardingSessionsCreated         OnboardingSession[]           @relation("OnboardingSessionCreator")
  onboardingRecordsCreated          Onboarding[]                  @relation("OnboardingCreator")
  nexaActions                       NexaAction[]                  @relation("NexaActionActor")
  microFranchiseReferrals           MicroFranchiseApplication[]   @relation("MicroFranchiseReferrer")
  microFranchiseAssignments         MicroFranchiseApplication[]   @relation("MicroFranchiseAssignee")
  microFranchisePartner             MicroFranchisePartner?
  nexaCoachingLogs                  NexaCoachingLog[]
  nexaCompetitionParticipants       NexaCompetitionParticipant[]
  nexaCompetitionsCreated           NexaCompetition[]             @relation("NexaCompetitionCreator")
  nexaEmployeeWelfare               NexaEmployeeWelfare[]
  nexaAnnouncementsCreated          NexaAnnouncement[]            @relation("NexaAnnouncementCreator")
  nexaPersuasionStates              NexaPersuasionState[]
  internalWallet                    InternalWallet?
  internalRewardClaims              InternalRewardClaim[]
  internalCompetitionProgress       InternalCompetitionProgress[]
  internalCompetitionsCreated       InternalCompetition[]         @relation("InternalCompetitionCreator")
  internalWithdrawals               InternalWithdrawal[]          @relation("WithdrawalOwner")
  internalWithdrawalsProcessed      InternalWithdrawal[]          @relation("WithdrawalProcessor")
  internalRecurringState            InternalRecurringState?
  internalNexaState                 InternalNexaState?
  internalTrainingMaterials         InternalTrainingMaterial[]    @relation("TrainingUploader")
  internalLeaderboard               InternalLeaderboard?
  internalTechTasksAssigned         InternalTechTask[]            @relation("TechTaskAssignee")
  internalTechTasksCreated          InternalTechTask[]            @relation("TechTaskCreator")
  internalFraudLogsTriggered        InternalFraudLog[]            @relation("FraudLogTrigger")

  /**
   * ICECONNECT workforce identity — when set to ICECONNECT, user may use /iceconnect/{rsm,bdm,bde,tech}.
   * Null = legacy users (routing uses {@link UserCompany.jobRole} only).
   */
  employeeSystem         EmployeeSystem?
  employeeDomain         EmployeeDomain?
  iceconnectEmployeeRole IceconnectEmployeeRole?
  parentId               String?
  parent                 User?   @relation("IceconnectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  iceconnectChildren     User[]  @relation("IceconnectHierarchy")

  onboardingRequestsCreated OnboardingRequest[] @relation("OnboardingRequestCreator")
  onboardingRequestBossFor  OnboardingRequest[] @relation("OnboardingRequestBossUser")
  onboardingPipelineSource  OnboardingPipeline[] @relation("OnboardingPipelineSource")
  onboardingPipelineAsRsm   OnboardingPipeline[] @relation("OnboardingPipelineAssignedRsm")
  onboardingPipelineAsBdm   OnboardingPipeline[] @relation("OnboardingPipelineAssignedBdm")
  onboardingPipelineAsBde   OnboardingPipeline[] @relation("OnboardingPipelineAssignedBde")
  ownershipClaimsRequested  OwnershipClaim[]      @relation("OwnershipClaimRequester")
  ownershipClaimsAsOwner    OwnershipClaim[]      @relation("OwnershipClaimCurrentOwner")
  usageFlagsHandled         UsageFlag[]           @relation("UsageFlagHandledBy")
  usageCapacityNotifications UsageCapacityNotification[]
  bdeMissions                BdeMission[]
  bdeTasks                   BdeTask[]
  bdeProspects               BdeProspect[]
  bdeStreak                  BdeStreak?
  bdeRewards                 BdeReward[]
  bdeWallet                  BdeWallet?
  bdeWalletTransactions      BdeWalletTransaction[]
  bdeWithdrawRequests        BdeWithdrawRequest[]
  bdeOnboarding              BdeOnboarding?
  userMissions               UserMission[]
  userTasks                  UserTask[]

  @@index([email])
  @@index([parentId])
  @@index([employeeSystem, iceconnectEmployeeRole])
}

/// ICECONNECT BDE daily Nexa mission (prospecting goal).
enum BdeMissionStatus {
  PENDING
  COMPLETED
}

enum BdeTaskStatus {
  PENDING
  DONE
}

enum BdeProspectPipelineStage {
  NEW
  CONTACTED
  TRIAL_STARTED
  CONVERTED
}

enum BdeRewardStatus {
  LOCKED
  UNLOCKED
  REVEALED
}

model BdeMission {
  id               String           @id @default(cuid())
  userId           String
  /// Calendar date (UTC) for the mission day.
  date             DateTime         @db.Date
  targetProspects  Int              @default(5)
  completedCount   Int              @default(0)
  callsLogged      Int              @default(0)
  status           BdeMissionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     BdeTask[]
  prospects BdeProspect[]

  @@unique([userId, date])
  @@index([userId, date])
  @@map("bde_missions")
}

model BdeTask {
  id        String        @id @default(cuid())
  userId    String
  missionId String
  taskText  String
  status    BdeTaskStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission BdeMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId, status])
  @@map("bde_tasks")
}

/// Field prospect captured by BDE (Nexa mission progress).
model BdeProspect {
  id             String                     @id @default(cuid())
  userId         String
  missionId      String?
  companyName    String
  phone          String
  location       String?
  pipelineStage  BdeProspectPipelineStage   @default(NEW)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission BdeMission? @relation(fields: [missionId], references: [id], onDelete: SetNull)
  userMissionId String?
  userMission   UserMission? @relation(fields: [userMissionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userMissionId])
  @@map("bde_prospects")
}

model BdeStreak {
  userId         String    @id
  currentStreak  Int       @default(0)
  lastActiveDate DateTime? @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bde_streaks")
}

model BdeReward {
  id        String          @id @default(cuid())
  userId    String
  type      String
  value     String
  status    BdeRewardStatus @default(LOCKED)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("bde_rewards")
}

/// ICECONNECT BDE earnings wallet (not micro-franchise {@link Wallet}).
model BdeWallet {
  id                 String   @id @default(cuid())
  userId             String   @unique
  totalEarned        Float    @default(0)
  withdrawableAmount Float    @default(0)
  bonusAmount        Float    @default(0)
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bde_wallets")
}

enum BdeWalletTransactionType {
  EARNING
  BONUS
  REWARD
}

model BdeWalletTransaction {
  id          String                   @id @default(cuid())
  userId      String
  type        BdeWalletTransactionType
  amount      Float
  /// Idempotency key: e.g. `prospect:<id>`, `reward:<type>`.
  referenceId String?
  createdAt   DateTime                 @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, referenceId])
  @@map("bde_wallet_transactions")
}

enum BdeWithdrawRequestStatus {
  PENDING
  APPROVED
  PAID
}

model BdeWithdrawRequest {
  id        String                   @id @default(cuid())
  userId    String
  amount    Float
  status    BdeWithdrawRequestStatus @default(PENDING)
  createdAt DateTime                 @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("bde_withdraw_requests")
}

/// 7-day Nexa BDE onboarding journey (checklist + day progression).
model BdeOnboarding {
  userId       String   @id
  currentDay   Int      @default(1)
  startedAt    DateTime @default(now())
  completed    Boolean  @default(false)
  /// Per-day completed task keys: `{ "1": ["d1_intro", ...], "2": [...] }`
  progressJson Json     @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bde_onboarding")
}

/// Unified BDE mission (onboarding day or daily) — one row per user per calendar day.
enum UserMissionType {
  ONBOARDING
  DAILY
}

enum UserMissionStatus {
  PENDING
  COMPLETED
}

enum UserTaskStatus {
  PENDING
  DONE
}

model UserMission {
  id             String            @id @default(cuid())
  userId         String
  missionDate    DateTime          @db.Date
  type           UserMissionType
  /// Set when type = ONBOARDING (which journey day 1–7).
  onboardingDay  Int?
  targetCount    Int
  completedCount Int             @default(0)
  callsLogged    Int               @default(0)
  status         UserMissionStatus @default(PENDING)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      UserTask[]
  prospects  BdeProspect[]

  @@unique([userId, missionDate])
  @@index([userId, missionDate])
  @@map("user_missions")
}

model UserTask {
  id            String        @id @default(cuid())
  userId        String
  userMissionId String
  taskKey       String
  label         String
  status        UserTaskStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission UserMission @relation(fields: [userMissionId], references: [id], onDelete: Cascade)

  @@unique([userMissionId, taskKey])
  @@index([userMissionId, status])
  @@map("user_tasks")
}

/// BDE-initiated company onboarding pipeline (BDE → Sales → Tech → Boss account).
enum OnboardingRequestDashboardType {
  SOLAR
  BUILDER
  ACADEMY
  CUSTOM
}

enum OnboardingRequestStatus {
  PENDING
  SALES_REVIEW
  TECH_QUEUE
  COMPLETED
}

enum OnboardingPipelineSourceType {
  INBOUND
  BDE
  BDM
  RSM
}

enum OnboardingPipelineStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  SENT_TO_TECH
  COMPLETED
}

enum LeadOwnershipRole {
  BDE
  BDM
  RSM
}

enum LeadSourceType {
  INBOUND
  BDE
  BDM
  RSM
}

enum OwnershipClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model OnboardingRequest {
  id              String                         @id @default(cuid())
  createdByUserId String
  companyName     String
  bossEmail       String
  dashboardType   OnboardingRequestDashboardType
  /// Build target; mirrors {@link dashboardType} (e.g. solar → solar).
  template        OnboardingRequestDashboardType
  status          OnboardingRequestStatus        @default(PENDING)
  notes           String?                        @db.Text
  /// Sales review: team structure, roles, departments, expected users (JSON).
  salesQuestionnaire Json?
  techTemplate       String?
  techNotes          String?                      @db.Text
  bossUserId         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User  @relation("OnboardingRequestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  bossUser  User? @relation("OnboardingRequestBossUser", fields: [bossUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([status])
  @@map("onboarding_requests")
}

model OnboardingPipeline {
  id             String                       @id @default(cuid())
  companyId      String?                      @map("company_id")
  companyName    String                       @map("company_name")
  sourceType     OnboardingPipelineSourceType @map("source_type")
  sourceUserId   String?                      @map("source_user_id")
  assignedRsmId  String?                      @map("assigned_rsm_id")
  assignedBdmId  String?                      @map("assigned_bdm_id")
  assignedBdeId  String?                      @map("assigned_bde_id")
  status         OnboardingPipelineStatus     @default(NEW)
  notes          String?                      @db.Text
  createdAt      DateTime                     @default(now()) @map("created_at")
  updatedAt      DateTime                     @updatedAt @map("updated_at")

  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sourceUser  User?    @relation("OnboardingPipelineSource", fields: [sourceUserId], references: [id], onDelete: SetNull)
  assignedRsm User?    @relation("OnboardingPipelineAssignedRsm", fields: [assignedRsmId], references: [id], onDelete: SetNull)
  assignedBdm User?    @relation("OnboardingPipelineAssignedBdm", fields: [assignedBdmId], references: [id], onDelete: SetNull)
  assignedBde User?    @relation("OnboardingPipelineAssignedBde", fields: [assignedBdeId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status, createdAt])
  @@index([assignedRsmId, status, createdAt])
  @@index([assignedBdmId, status, createdAt])
  @@index([assignedBdeId, status, createdAt])
  @@map("onboarding_pipeline")
}

/**
 * Sales-launch referral partner registry (cross-company).
 */
model LaunchChannelPartner {
  id           String    @id @default(cuid())
  phone        String    @unique
  name         String?
  totalRevenue Float     @default(0)
  conversions  Int       @default(0)
  createdAt    DateTime  @default(now())
  companies    Company[] @relation("LaunchPartnerCompany")
}

/**
 * Sales launch session used by Nexa chat onboarding flow.
 */
model OnboardingSession {
  id              String   @id @default(cuid())
  source          String?
  leadId          String?
  partnerId       String?
  companyId       String?
  companyName     String?
  industry        String?
  rawTeamInput    String?
  parsedTeam      Json?
  unknownRoles    Json?
  data            Json?
  currentStep     String?
  status          String   @default("draft")
  createdByUserId String
  createdAt       DateTime @default(now())

  creator User     @relation("OnboardingSessionCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([createdByUserId, createdAt])
  @@index([status])
  @@index([leadId])
  @@index([companyId])
}

/**
 * Tech exception queue created from launch unknown roles.
 */
model TechRequest {
  id          String   @id @default(cuid())
  roleName    String
  description String?
  companyId   String?
  status      String   @default("pending")
  priority    String   @default("HIGH")
  requestedBy String?
  createdAt   DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([companyId])
}

/**
 * Online micro-franchise applicant pipeline (APPLICATION → … → APPROVED).
 */
model MicroFranchiseApplication {
  id           String   @id @default(cuid())
  name         String
  phone        String
  email        String?
  location     String?
  experience   String?
  /// APPLICATION | REVIEW | TRAINING | MOU | APPROVED | REJECTED
  status       String   @default("APPLICATION")
  referredById String?
  assignedToId String?
  /// JSON array: { at: ISO string, body: string, authorEmail?: string }
  notes        Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referredBy User?                  @relation("MicroFranchiseReferrer", fields: [referredById], references: [id], onDelete: SetNull)
  assignedTo User?                  @relation("MicroFranchiseAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  partner    MicroFranchisePartner?

  @@index([status, createdAt])
  @@index([referredById])
  @@index([phone])
}

/**
 * Commission template for micro-franchise offers (boss-managed).
 */
model CommissionPlan {
  id           String   @id @default(cuid())
  name         String
  /// PERCENTAGE | FIXED
  type         String
  value        Float
  recurring    Boolean  @default(false)
  instantBonus Float?
  createdAt    DateTime @default(now())

  partners MicroFranchisePartner[]
}

/**
 * Activated micro-franchise partner (ICECONNECT login + referral phone as ID).
 */
model MicroFranchisePartner {
  id               String    @id @default(cuid())
  applicationId    String?   @unique
  name             String
  phone            String    @unique
  email            String?
  userId           String    @unique
  commissionPlanId String?
  performanceScore Float     @default(0)
  tier             String    @default("BRONZE")
  lastScoredAt     DateTime?
  createdAt        DateTime  @default(now())

  application            MicroFranchiseApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  user                   User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissionPlan         CommissionPlan?            @relation(fields: [commissionPlanId], references: [id], onDelete: SetNull)
  wallet                 Wallet?
  companies              Company[]
  commissionTransactions CommissionTransaction[]
  alerts                 MicroFranchiseAlert[]

  @@index([commissionPlanId])
}

model MicroFranchiseAlert {
  id        String   @id @default(cuid())
  partnerId String
  /// INACTIVE | GROWTH | RISK
  type      String
  /// LOW | MEDIUM | HIGH
  severity  String   @default("LOW")
  title     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner MicroFranchisePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([status, createdAt])
}

model Wallet {
  id          String   @id @default(cuid())
  partnerId   String   @unique
  balance     Float    @default(0)
  pending     Float    @default(0)
  totalEarned Float    @default(0)
  updatedAt   DateTime @updatedAt

  partner MicroFranchisePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model CommissionTransaction {
  id         String   @id @default(cuid())
  partnerId  String
  companyId  String
  amount     Float
  /// RECURRING | ONE_TIME
  type       String
  /// PENDING (awaiting boss release) | RELEASED (in partner balance) | PAID_OUT
  status     String   @default("PENDING")
  /// Idempotency: Razorpay payment id when commission sourced from subscription payment.
  paymentRef String?  @unique
  createdAt  DateTime @default(now())

  partner MicroFranchisePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([companyId])
  @@index([status])
}

/**
 * Monthly sales target + salary for ICECONNECT executives (internal org).
 */
model SalesExecutiveMonthlyTarget {
  id           String                 @id @default(cuid())
  companyId    String
  userId       String
  periodYear   Int
  periodMonth  Int
  targetCount  Int
  targetPlan   IceconnectCustomerPlan
  /**
   * Monthly salary in INR (eligible portion scales with target progress).
   */
  salaryRupees Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, periodYear, periodMonth])
  @@index([companyId])
  @@index([userId])
}

model Lead {
  id              String     @id @default(cuid())
  name            String
  phone           String
  email           String?
  source          String?
  status          LeadStatus @default(NEW)
  value           Float?
  companyId       String
  assignedTo      String?
  /**
   * User who created the lead in BGOS (audit / “boss vs team” views).
   */
  createdByUserId String?
  ownerUserId     String?            @map("owner_user_id")
  ownerRole       LeadOwnershipRole? @map("owner_role")
  sourceType      LeadSourceType?    @map("source_type")
  sourceUserId    String?            @map("source_user_id")
  partnerId       String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee       User?               @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User?               @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  owner          User?               @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sourceUser     User?               @relation("LeadSourceUser", fields: [sourceUserId], references: [id], onDelete: SetNull)
  partner        ChannelPartner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  deals          Deal[]
  tasks          Task[]
  quotations     Quotation[]
  invoices       Invoice[]
  documents      Document[]
  commissions    Commission[]
  siteVisits     SiteVisit[]
  approvals      Approval[]
  lcoLoans       LcoLoan[]
  customerUser   CustomerPortalUser?
  complaints     CustomerComplaint[]
  installations  Installation[]
  projects       Project[]
  serviceJobs    ServiceJob[]
  serviceTickets ServiceTicket[]
  siteReport     String?             @db.Text

  /**
   * Customer / prospect company name (internal sales).
   */
  leadCompanyName                  String?
  businessType                     String?
  internalSalesNotes               String?                           @db.Text
  internalSalesStage               InternalSalesStage?
  internalCallStatus               InternalCallStatus?
  lastContactedAt                  DateTime?
  nextFollowUpAt                   DateTime?
  internalTechStage                InternalTechStage?
  internalOnboardingApprovalStatus InternalOnboardingApprovalStatus?
  /**
   * SLA / escalation: last time sales or tech stage moved.
   */
  internalStageUpdatedAt           DateTime?

  /**
   * Sales-selected tier before onboarding form is opened (internal org).
   */
  onboardingType LeadOnboardingType?

  /**
   * ICECONNECT executive metro (internal org).
   */
  iceconnectLocation     String?
  iceconnectMetroStage   IceconnectMetroStage?
  iceconnectCustomerPlan IceconnectCustomerPlan?
  iceconnectSubscribedAt DateTime?
  /**
   * Nexa intelligence state for metro pipeline automation.
   */
  currentStage           String?
  lastActivityAt         DateTime?
  nextActionDue          DateTime?
  activityCount          Int                     @default(0)
  responseStatus         LeadResponseStatus      @default(RESPONSIVE)
  confidenceScore        Int                     @default(50)
  nexaPriority           Boolean                 @default(false)
  nexaMovedAt            DateTime?
  nexaMovedReason        String?

  onboardingTasks              OnboardingTask[]
  onboardingWorkflowSubmission OnboardingSubmission?
  onboardingSessions           OnboardingSession[]
  onboardingRecords            Onboarding[]
  ownershipClaims              OwnershipClaim[]
  internalLeadActivities       InternalLeadActivity[]
  nexaSupportTickets           InternalNexaSupportTicket[]

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
  @@index([createdByUserId])
  @@index([ownerUserId, ownerRole])
  @@index([partnerId])
  @@index([phone])
  @@index([companyId, email])
  @@index([companyId, phone])
  @@index([companyId, assignedTo, iceconnectMetroStage])
}

model OwnershipClaim {
  id             String               @id @default(cuid())
  companyId      String               @map("company_id")
  leadId         String?              @map("lead_id")
  requestedBy    String               @map("requested_by")
  currentOwnerId String?              @map("current_owner_id")
  status         OwnershipClaimStatus @default(PENDING)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  requester    User    @relation("OwnershipClaimRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  currentOwner User?   @relation("OwnershipClaimCurrentOwner", fields: [currentOwnerId], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt])
  @@index([leadId, status])
  @@map("ownership_claims")
}

model Onboarding {
  id        String           @id @default(cuid())
  leadId    String
  companyId String?
  status    OnboardingStatus @default(IN_PROGRESS)
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  meta      Json?

  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creator User     @relation("OnboardingCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([leadId, status])
  @@index([createdBy, createdAt])
  @@index([companyId])
}

model Deal {
  id        String     @id @default(cuid())
  leadId    String
  companyId String
  value     Float
  status    DealStatus
  stage     String?
  createdAt DateTime   @default(now())

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([companyId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  userId      String?
  leadId      String?
  companyId   String
  priority    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status, priority])
}

model Automation {
  id        String @id @default(cuid())
  name      String
  trigger   String
  action    String
  config    Json
  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, trigger])
}

model NexaAction {
  id          String   @id @default(cuid())
  type        String
  event       String
  target      String
  status      String
  message     String
  metadata    Json?
  executedAt  DateTime @default(now())
  companyId   String
  actorUserId String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation("NexaActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, executedAt])
  @@index([companyId, event])
  @@index([status])
}

model Installation {
  id            String    @id @default(cuid())
  status        String
  scheduledDate DateTime?
  companyId     String
  leadId        String?
  assignedTo    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee User?   @relation("InstallationAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([status])
  @@index([leadId])
  @@index([assignedTo])
}

/// Solar project lifecycle (planning -> execution -> closure), company-scoped.
model Project {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String?
  name        String
  status      String   @default("PLANNED")
  startDate   DateTime?
  endDate     DateTime?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([leadId])
  @@index([status])
  @@map("projects")
}

/// Solar service jobs (post-install or support), company-scoped.
model ServiceJob {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String?
  title       String
  status      String   @default("OPEN")
  scheduledAt DateTime?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
  @@map("services")
}

/// Inventory master for solar operations (stock ledger stays in ProductMovement).
model InventoryItem {
  id        String   @id @default(cuid())
  companyId String
  name      String
  sku       String?
  quantity  Int      @default(0)
  unit      String   @default("unit")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
  @@map("inventory")
}

model Payment {
  id        String        @id @default(cuid())
  amount    Float
  status    PaymentStatus
  companyId String
  createdAt DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

/// Customer quotation (money layer). Numbers are per-company unique (e.g. Q-0001).
model Quotation {
  id              String   @id @default(cuid())
  companyId       String
  leadId          String?
  /**
   * Snapshot / override when not using a lead or for PDF display.
   */
  customerName    String?
  customerPhone   String?
  quotationNumber String
  status          String
  totalAmount     Float
  items           Json
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Invoice linked optionally to quotation + lead.
model Invoice {
  id             String    @id @default(cuid())
  companyId      String
  quotationId    String?
  leadId         String?
  invoiceNumber  String
  status         String
  totalAmount    Float
  paidAmount     Float     @default(0)
  dueDate        DateTime?
  items          Json
  pricingVersion String    @default("v1.0")
  createdAt      DateTime  @default(now())

  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotation Quotation?       @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  lead      Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  payments  InvoicePayment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([quotationId])
  @@index([leadId])
  @@index([status])
}

/// Payment allocated to an invoice (distinct from legacy `Payment` register rows).
model InvoicePayment {
  id        String   @id @default(cuid())
  companyId String
  invoiceId String
  amount    Float
  method    String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@index([date])
}

model Expense {
  id        String   @id @default(cuid())
  companyId String
  title     String
  amount    Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
}

model ServiceTicket {
  id          String              @id @default(cuid())
  title       String
  description String?             @db.Text
  status      ServiceTicketStatus @default(OPEN)
  companyId   String
  leadId      String?
  assignedTo  String?
  issue       String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([leadId])
  @@index([assignedTo])
}

model SiteVisit {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  assignedTo String
  /// SCHEDULED | COMPLETED
  status     String
  report     Json?
  createdAt  DateTime @default(now())

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User    @relation("SiteVisitAssignee", fields: [assignedTo], references: [id], onDelete: Restrict)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([assignedTo])
  @@index([status])
}

model Approval {
  id        String   @id @default(cuid())
  companyId String
  leadId    String
  /// PENDING | APPROVED | REJECTED
  status    String
  notes     String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([status])
}

/// Company file storage: agreements, approvals, site reports, customer docs.
model Document {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String?
  customerId       String?
  /// AGREEMENT | APPROVAL | REPORT | OTHER
  type             String
  /// Storage key: `{companyId}/documents/{yyyy}/{mm}/{unique}-{safeName}` (local disk or S3 object key).
  fileUrl          String
  fileName         String
  createdAt        DateTime @default(now())
  /// Who uploaded (nullable for legacy rows before audit columns).
  uploadedByUserId String?
  /// `UserRole` at upload time (membership can change later).
  uploadedByRole   String?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  uploader User?   @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, uploadedByUserId])
  @@index([leadId])
  @@index([customerId])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  fromDate  DateTime
  toDate    DateTime
  reason    String
  /// PENDING | APPROVED | REJECTED
  status    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, status])
}

model Attendance {
  id        String    @id @default(cuid())
  companyId String
  userId    String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, date])
  @@index([companyId])
  @@index([userId])
}

model Salary {
  id        String @id @default(cuid())
  companyId String
  userId    String
  amount    Float
  month     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, month])
  @@index([companyId])
  @@index([userId])
}

model Product {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  /// Panel | Inverter | Battery | Accessories
  category      String
  unit          String
  minStockLevel Float    @default(5)
  createdAt     DateTime @default(now())

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks  Stock[]
  logs    StockLog[]

  @@index([companyId])
  @@index([companyId, category])
}

model Stock {
  id        String   @id @default(cuid())
  companyId String
  productId String
  quantity  Float
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId])
  @@index([companyId])
}

model StockLog {
  id        String   @id @default(cuid())
  companyId String
  productId String
  /// IN | OUT
  type      String
  quantity  Float
  reference String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([companyId, type])
}

model ChannelPartner {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  phone           String
  createdByUserId String
  createdAt       DateTime @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator     User         @relation("PartnerCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  leads       Lead[]
  commissions Commission[]

  @@index([companyId])
  @@index([createdByUserId])
}

model Commission {
  id        String   @id @default(cuid())
  companyId String
  partnerId String
  leadId    String
  amount    Float
  /// DIRECT | REFERRAL
  type      String
  /// PENDING | PAID
  status    String
  createdAt DateTime @default(now())

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner ChannelPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  lead    Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([partnerId])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  companyId String?
  userId    String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

/// Internal sales → tech handoff (one row per won lead).
model OnboardingTask {
  id                   String               @id @default(cuid())
  companyId            String
  leadId               String               @unique
  status               OnboardingTaskStatus @default(NEW)
  snapshotCompanyName  String
  snapshotOwnerName    String
  snapshotPhone        String
  snapshotEmail        String?
  snapshotBusinessType String?
  snapshotTeamSize     String?
  snapshotLeadSources  String?              @db.Text
  snapshotProblems     String?              @db.Text
  snapshotRequirements String?              @db.Text
  snapshotPlan         String?
  snapshotWhatsApp     String?
  /**
   * Tier at submit time; drives tech queue priority.
   */
  leadOnboardingType   LeadOnboardingType?
  techQueuePriority    TechQueuePriority    @default(LOW)
  pipelineStage        TechPipelineStage    @default(RECEIVED)
  /**
   * Extra onboarding fields (team counts, social, enterprise, etc.).
   */
  formPayload          Json?
  createdByUserId      String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator User    @relation("OnboardingTaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([status])
  @@index([companyId, techQueuePriority])
  @@index([companyId, pipelineStage])
}

/// One active manual per {@link UserManualCategory} per company (upsert on upload).
model UserManual {
  id        String             @id @default(cuid())
  companyId String
  category  UserManualCategory
  title     String
  fileUrl   String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, category])
  @@index([companyId])
}

/// Nexa support requests (internal org).
model InternalNexaSupportTicket {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String?
  createdByUserId  String
  /**
   * CALLBACK | MEETING | ISSUE
   */
  option           String
  /**
   * TECHNICAL | TRAINING | PAYMENT | OTHER
   */
  category         String
