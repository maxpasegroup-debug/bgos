// BGOS + ICECONNECT — multi-company schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  BDM
  /**
   * BGOS Internal tech lead (delivery pipeline).
   */
  TECH_HEAD
  /**
   * BGOS Internal tech execution (delivery pipeline).
   */
  TECH_EXECUTIVE
}

/// Which product surface this user belongs to (ICECONNECT = field / solar workforce app).
enum EmployeeSystem {
  BGOS
  ICECONNECT
}

/// Business domain for data flow to BGOS Boss (brain vs solar install base).
enum EmployeeDomain {
  BGOS
  SOLAR
}

/// ICECONNECT mobile hierarchy role (orthogonal to {@link UserRole} jobRole).
enum IceconnectEmployeeRole {
  RSM
  BDM
  BDE
  TECH_EXEC
}

enum CompanyPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum BdmEarningType {
  DIRECT
  RECURRING
  ENTERPRISE
}

enum BdmEarningStatus {
  PENDING
  APPROVED
  PAID
}

/**
 * Derived billing/trial state; kept in sync on writes and subscription reads.
 */
enum CompanySubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  /**
   * Custom-build workspaces: selected plan but initial subscription payment not completed yet.
   */
  PAYMENT_PENDING
}

enum CompanyIndustry {
  SOLAR
  CUSTOM
}

/**
 * Product line: solar CRM vs paid custom dashboard build.
 */
enum CompanyBusinessType {
  SOLAR
  CUSTOM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  SITE_VISIT_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  /**
   * Quotation approved — booked, awaiting payment.
   */
  PROPOSAL_WON
  WON
  LOST
}

enum LeadResponseStatus {
  RESPONSIVE
  SILENT
  COOLING
}

/**
 * BGOS Internal sales metro pipeline (company with `internalSalesOrg`). Linear order — no skips.
 */
enum InternalSalesStage {
  LEAD_ADDED
  INTRO_CALL
  DEMO_ORIENTATION
  FOLLOW_UP
  INTERESTED
  ONBOARDING_FORM_FILLED
  BOSS_APPROVAL_PENDING
  SENT_TO_TECH
  TECH_READY
  DELIVERED
  CLIENT_LIVE
  CLOSED_LOST
}

/**
 * Tech delivery metro (after Sent to Tech).
 */
enum InternalTechStage {
  ONBOARDING_RECEIVED
  DATA_VERIFIED
  DASHBOARD_SETUP
  EMPLOYEE_SETUP
  SYSTEM_TESTING
  READY_FOR_DELIVERY
}

enum InternalOnboardingApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InternalCallStatus {
  NOT_CALLED
  CALLED
  NO_ANSWER
  INTERESTED
  NOT_INTERESTED
}

/**
 * ICECONNECT sales executive metro pipeline (internal org). SUBSCRIPTION = converted customer.
 */
enum IceconnectMetroStage {
  LEAD_CREATED
  INTRO_CALL
  DEMO_DONE
  FOLLOW_UP
  ONBOARDING
  PAYMENT_DONE
  SUBSCRIPTION
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
}

/**
 * Plan tier for executive targets and converted ICECONNECT customers.
 */
enum IceconnectCustomerPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

/**
 * Category for a single active user manual PDF per company.
 */
enum UserManualCategory {
  SALES
  OPERATIONS
  HR
  ACCOUNTS
  SALES_BOOSTER
}

/**
 * Internal CRM: onboarding tier chosen by sales before the client form opens.
 */
enum LeadOnboardingType {
  BASIC
  PRO
  ENTERPRISE
}

/**
 * Tech queue sort: Enterprise first, then Pro, then Basic.
 */
enum TechQueuePriority {
  CRITICAL
  HIGH
  LOW
}

/**
 * Tech delivery steps (no skipping). Synced to {@link InternalTechStage} on the lead when possible.
 */
enum TechPipelineStage {
  RECEIVED
  SETUP_DASHBOARD
  ADD_EMPLOYEES
  CONFIGURE_MODULES
  TESTING
  READY
}

/**
 * Tech onboarding queue for internal sales → delivery.
 */
enum OnboardingTaskStatus {
  NEW
  DATA_RECEIVED
  SETUP_STARTED
  SETUP_COMPLETED
  DELIVERED
}

enum DealStatus {
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum PaymentStatus {
  PAID
  PENDING
}

enum ServiceTicketStatus {
  OPEN
  RESOLVED
}

/**
 * BGOS onboarding workflow templates (category + tier).
 */
enum OnboardingWorkflowPlanTier {
  BASIC
  PRO
  ENTERPRISE
}

enum OnboardingSubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_INFO
  READY
  DELIVERED
}

enum OnboardingTechTaskStatus {
  NEW
  IN_PROGRESS
  WAITING_INFO
  READY
  DELIVERED
}

model Company {
  id           String              @id @default(cuid())
  name         String
  industry     CompanyIndustry     @default(SOLAR)
  /**
   * Solar (default trial path) vs custom paid build — see {@link CompanyBusinessType}.
   */
  businessType CompanyBusinessType @default(SOLAR)
  /**
   * Subscription tier; remains {@link CompanyPlan} in DB (not a free-form string).
   */
  plan         CompanyPlan         @default(BASIC)
  ownerId      String
  /// Tenant routing: SOLAR (solar boss) vs BGOS (default brain).
  workspaceDomain EmployeeDomain @default(SOLAR)
  /// Onboarding dashboard template (solar, builder, academy, custom).
  dashboardTemplate OnboardingRequestDashboardType @default(SOLAR)
  createdAt    DateTime            @default(now())

  /**
   * Clock start for the 15-day BASIC trial; null = pre-trial schema / grandfathered.
   */
  trialStartDate DateTime?
  /**
   * Exclusive wall-clock end: expired when `now >= trialEndDate` for BASIC.
   */
  trialEndDate   DateTime?
  isTrialActive  Boolean   @default(true)

  /**
   * Subscription status (trial / active paid / expired trial).
   * Canonical plan tier remains {@link CompanyPlan} in `plan`. Trial end instant remains `trialEndDate`
   * (APIs may expose it as `trialEndsAt`).
   */
  subscriptionStatus      CompanySubscriptionStatus @default(TRIAL)
  /**
   * Wall-clock start of the current paid Razorpay/Stripe period (optional).
   */
  subscriptionPeriodStart DateTime?
  /**
   * Paid access valid strictly before this instant (Razorpay monthly renewals extend this).
   */
  subscriptionPeriodEnd   DateTime?

  logoUrl        String?
  primaryColor   String?
  secondaryColor String?

  /**
   * Public / document-facing profile (quotations, invoices, PDFs).
   */
  companyEmail   String?
  companyPhone   String?
  billingAddress String? @db.Text
  gstNumber      String?
  bankDetails    String? @db.Text

  businessTemplate String?
  dashboardConfig  Json?

  /**
   * True for the dedicated BGOS internal sales tenant (“BGOS Internal”).
   */
  internalSalesOrg               Boolean @default(false)
  /**
   * Optional default assignee for public / anonymous lead capture.
   */
  internalSalesDefaultAssigneeId String?
  /**
   * Round-robin: last tech user id assigned to an onboarding workflow submission.
   */
  internalWorkflowLastTechUserId String?

  /**
   * Set when the customer completes the custom requirements form (custom businessType only).
   */
  customOnboardingSubmittedAt     DateTime?
  /**
   * After internal sales confirms final payment, tech may contact the client and start build.
   * Until then: internal planning only (no client comms).
   */
  customBuildClientContactAllowed Boolean   @default(false)
  customFinalPaymentConfirmedAt   DateTime?

  /**
   * Platform (super boss): hide archived tenants from the client directory.
   */
  archivedAt              DateTime?
  /**
   * Optional referral phone captured at launch.
   */
  referralPhone           String?
  /**
   * Acquisition channel for Nexa / CRM attribution: direct, sales, franchise.
   */
  sourceType String? @map("source_type")
  /**
   * Stable id for attribution (e.g. internal lead id, franchise partner id).
   */
  sourceId   String? @map("source_id")

  owner                        User                              @relation("OwnedCompany", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships                  UserCompany[]
  leads                        Lead[]
  deals                        Deal[]
  tasks                        Task[]
  installations                Installation[]
  projects                     Project[]
  payments                     Payment[]
  quotations                   Quotation[]
  moneyInvoices                Invoice[]
  expenses                     Expense[]
  invoicePayments              InvoicePayment[]
  activityLogs                 ActivityLog[]
  serviceTickets               ServiceTicket[]
  serviceJobs                  ServiceJob[]
  automations                  Automation[]
  nexaActions                  NexaAction[]
  documents                    Document[]
  leaveRequests                LeaveRequest[]
  attendances                  Attendance[]
  salaries                     Salary[]
  products                     Product[]
  stocks                       Stock[]
  stockLogs                    StockLog[]
  siteVisits                   SiteVisit[]
  approvals                    Approval[]
  growthPlan                   CompanyGrowthPlan?
  razorpayPayments             RazorpayPayment[]
  onboardingTasks              OnboardingTask[]
  internalLeadActivities       InternalLeadActivity[]
  internalInAppNotifications   InternalInAppNotification[]
  internalNexaSupportTickets   InternalNexaSupportTicket[]
  userManuals                  UserManual[]
  onboardingFormTemplates      OnboardingFormTemplate[]
  onboardingSubmissions        OnboardingSubmission[]
  onboardingSessions           OnboardingSession[]
  onboardingRecords            Onboarding[]
  onboardingPipeline           OnboardingPipeline[]
  ownershipClaims             OwnershipClaim[]
  techRequests                 TechRequest[]
  techQueueEntries             TechQueueEntry[]
  bdmEarnings                  BdmEarning[]
  nexaTasks                    NexaTask[]
  techRoundRobinState          TechRoundRobinState?
  nexaCoachingLogs             NexaCoachingLog[]
  nexaCompetitions             NexaCompetition[]
  nexaEmployeeWelfare          NexaEmployeeWelfare[]
  nexaAnnouncements            NexaAnnouncement[]
  nexaPersuasionStates         NexaPersuasionState[]
  /// Plan caps for users / leads / projects (solar boss scaling gate).
  companyLimit                 CompanyLimit?
  subscription                 Subscription?
  usageMetric                  UsageMetric?
  usageFlags                   UsageFlag[]
  usageCapacityNotifications   UsageCapacityNotification[]

  @@index([name])
  @@index([ownerId])
}

/// Enforces max users, leads, and projects per company (upgrade path when exceeded).
model CompanyLimit {
  id          String @id @default(cuid())
  companyId   String @unique
  maxUsers    Int    @default(12)
  maxLeads    Int    @default(300)
  maxProjects Int    @default(50)
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_limits")
}

/// Billing subscription snapshot per company (explicit payment layer table).
model Subscription {
  id        String                    @id @default(cuid())
  companyId String                    @unique
  plan      CompanyPlan
  status    CompanySubscriptionStatus
  expiry    DateTime
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("subscriptions")
}

/// Cached tenant usage for capacity alerts (recalculated daily or on demand).
model UsageMetric {
  id              String   @id @default(cuid())
  companyId       String   @unique
  currentUsers    Int      @default(0)
  currentLeads    Int      @default(0)
  currentProjects Int      @default(0)
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("usage_metrics")
}

enum UsageFlagKind {
  USERS
  LEADS
  PROJECTS
}

enum UsageFlagStatus {
  ACTIVE
  IN_PROGRESS
  CONVERTED
  CLOSED
}

enum UsageCapacityNotificationStatus {
  UNREAD
  READ
}

/// High-usage (e.g. ≥80% of cap) capacity flag for sales follow-up.
model UsageFlag {
  id            String            @id @default(cuid())
  companyId     String
  kind          UsageFlagKind
  status        UsageFlagStatus   @default(ACTIVE)
  handledById   String?
  /// UI workflow: pending → contacted → closed (parallel to {@link status}).
  actionStatus  String            @default("pending")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  company       Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  handledBy     User?                       @relation("UsageFlagHandledBy", fields: [handledById], references: [id], onDelete: SetNull)
  notifications UsageCapacityNotification[]

  @@index([companyId, kind, status])
  @@index([companyId, status])
  @@map("usage_flags")
}

/// In-app alerts for ICECONNECT sales (RSM / BDM / BDE) when capacity flags fire.
model UsageCapacityNotification {
  id          String                          @id @default(cuid())
  companyId   String
  userId      String
  usageFlagId String?
  message     String                          @db.Text
  status      UsageCapacityNotificationStatus   @default(UNREAD)
  createdAt   DateTime                        @default(now())
  readAt      DateTime?

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageFlag UsageFlag? @relation(fields: [usageFlagId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([companyId])
  @@map("usage_capacity_notifications")
}

/**
 * Omnichannel Sales Booster — channel identifiers (UI + API).
 */
enum SalesBoosterOmnichannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
  SMS
}

enum SalesBoosterConnectionState {
  DISCONNECTED
  PENDING
  CONNECTED
}

enum SalesBoosterCampaignState {
  DRAFT
  SCHEDULED
  SENT
  PAUSED
}

/**
 * In-app omnichannel thread messages (company-scoped). Mapped to `sales_booster_messages`.
 */

/**
 * Boss monthly targets on Home — drives projections (1Y / multi-year copy).
 */
model CompanyGrowthPlan {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  targetRevenueOneMonth Float    @default(0)
  targetLeadsOneMonth   Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}


/// Processed billing webhook deliveries (e.g. Stripe `evt_*`) — prevents double-applying upgrades.
model BillingWebhookEvent {
  id         String   @id @default(cuid())
  provider   String   @default("stripe")
  externalId String   @unique
  eventType  String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

/// Razorpay Checkout payments (verify path + idempotency).
model RazorpayPayment {
  id                String      @id @default(cuid())
  companyId         String
  userId            String
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique
  plan              CompanyPlan
  amount            Int
  currency          String      @default("INR")
  status            String
  pricingVersion    String      @default("v1.0")
  createdAt         DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

model BdmEarning {
  id              String           @id @default(cuid())
  bdmUserId       String
  clientCompanyId String
  type            BdmEarningType
  plan            String
  amount          Int
  month           String
  periodStart     DateTime
  periodEnd       DateTime
  status          BdmEarningStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  paidAt          DateTime?
  notes           String?
  paymentRef      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  bdmUser       User    @relation(fields: [bdmUserId], references: [id])
  clientCompany Company @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)

  @@index([bdmUserId, month])
  @@index([status])
  @@index([clientCompanyId])
}

/// Membership: `role` is company-level (ADMIN vs EMPLOYEE); `jobRole` is operational RBAC (solar CRM role enum).
model UserCompany {
  id                String   @id @default(cuid())
  userId            String
  companyId         String
  role              String
  jobRole           UserRole
  dashboardAssigned String?
  /// READY | PENDING_BUILD | IN_PROGRESS | LIVE
  status            String   @default("READY")
  createdAt         DateTime @default(now())
  archivedAt        DateTime?
  createdByUserId          String?

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("MembershipCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@index([createdByUserId])
  /// Compound index for paginated team roster queries ordered by join date.
  @@index([companyId, createdAt])
}

enum TechQueueStatus {
  PENDING
  ASSIGNED
  DONE
  CANCELLED
}

enum NexaTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum NexaTaskPriority {
  LOW
  MEDIUM
  HIGH
}


model TechQueueEntry {
  id                 String          @id @default(cuid())
  companyId          String
  requestId          String
  assignedToUserId   String?
  status             TechQueueStatus @default(PENDING)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([assignedToUserId])
  @@map("tech_queue")
}

model NexaTask {
  id        String         @id @default(cuid())
  companyId String
  userId    String
  task      String         @db.Text
  status    NexaTaskStatus @default(PENDING)
  priority  NexaTaskPriority @default(MEDIUM)
  dueDate   DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, status])
  @@map("nexa_tasks")
}

/// Single row per company — cursor for tech_exec round-robin.
model TechRoundRobinState {
  companyId          String @id
  lastAssignedUserId String?
  position           Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("tech_round_robin_state")
}

model User {
  id                   String    @id @default(cuid())
  name                 String
  /**
   * Globally unique login identity (boss, employees, ICECONNECT).
   */
  email                String    @unique
  password             String
  mobile               String?   @unique
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  /**
   * Set when the boss completes onboarding step 2 (NEXA activation). Invited employees get this on create.
   */
  workspaceActivatedAt DateTime?
  /**
   * Force one-time password reset on first successful login.
   */
  firstLogin           Boolean   @default(false)
  /**
   * Hard gate for credentials minted during onboarding/import.
   */
  forcePasswordReset   Boolean   @default(false)
  /**
   * Updated on every successful authentication.
   */
  lastLogin            DateTime?

  companiesOwned                    Company[]                     @relation("OwnedCompany")
  memberships                       UserCompany[]
  membershipsCreated                UserCompany[]                 @relation("MembershipCreatedBy")
  techQueueAssignments              TechQueueEntry[]
  nexaTasks                         NexaTask[]
  assignedLeads                     Lead[]                        @relation("LeadAssignee")
  leadsCreated                      Lead[]                        @relation("LeadCreator")
  leadsOwned                        Lead[]                        @relation("LeadOwner")
  leadsSourced                      Lead[]                        @relation("LeadSourceUser")
  tasks                             Task[]
  activityLogs                      ActivityLog[]
  assignedInstallations             Installation[]                @relation("InstallationAssignee")
  assignedServiceTickets            ServiceTicket[]               @relation("TicketAssignee")
  leaveRequests                     LeaveRequest[]
  attendances                       Attendance[]
  salaries                          Salary[]
  assignedSiteVisits                SiteVisit[]                   @relation("SiteVisitAssignee")
  documentsUploaded                 Document[]
  razorpayPayments                  RazorpayPayment[]
  onboardingTasksCreated            OnboardingTask[]              @relation("OnboardingTaskCreator")
  internalLeadActivities            InternalLeadActivity[]
  internalInAppNotifications        InternalInAppNotification[]
  internalNexaSupportTicketsCreated InternalNexaSupportTicket[]   @relation("NexaSupportCreator")
  onboardingSubmissionsFilled       OnboardingSubmission[]        @relation("OnboardingFilledBy")
  onboardingSubmissionsTech         OnboardingSubmission[]        @relation("OnboardingTechAssignee")
  onboardingWorkflowMessages        OnboardingMessage[]
  onboardingSessionsCreated         OnboardingSession[]           @relation("OnboardingSessionCreator")
  onboardingRecordsCreated          Onboarding[]                  @relation("OnboardingCreator")
  nexaActions                       NexaAction[]                  @relation("NexaActionActor")
  nexaCoachingLogs                  NexaCoachingLog[]
  nexaCompetitionParticipants       NexaCompetitionParticipant[]
  nexaCompetitionsCreated           NexaCompetition[]             @relation("NexaCompetitionCreator")
  nexaEmployeeWelfare               NexaEmployeeWelfare[]
  nexaAnnouncementsCreated          NexaAnnouncement[]            @relation("NexaAnnouncementCreator")
  nexaPersuasionStates              NexaPersuasionState[]
  internalWallet                    InternalWallet?
  internalRewardClaims              InternalRewardClaim[]
  internalCompetitionProgress       InternalCompetitionProgress[]
  internalCompetitionsCreated       InternalCompetition[]         @relation("InternalCompetitionCreator")
  internalWithdrawals               InternalWithdrawal[]          @relation("WithdrawalOwner")
  internalWithdrawalsProcessed      InternalWithdrawal[]          @relation("WithdrawalProcessor")
  internalRecurringState            InternalRecurringState?
  internalNexaState                 InternalNexaState?
  internalTrainingMaterials         InternalTrainingMaterial[]    @relation("TrainingUploader")
  internalLeaderboard               InternalLeaderboard?
  internalTechTasksAssigned         InternalTechTask[]            @relation("TechTaskAssignee")
  internalTechTasksCreated          InternalTechTask[]            @relation("TechTaskCreator")
  internalFraudLogsTriggered        InternalFraudLog[]            @relation("FraudLogTrigger")
  bdmEarnings                       BdmEarning[]

  /**
   * ICECONNECT workforce identity — when set to ICECONNECT, user may use /iceconnect/{rsm,bdm,bde,tech}.
   * Null = legacy users (routing uses {@link UserCompany.jobRole} only).
   */
  employeeSystem         EmployeeSystem?
  employeeDomain         EmployeeDomain?
  iceconnectEmployeeRole IceconnectEmployeeRole?
  parentId               String?
  parent                 User?   @relation("IceconnectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  iceconnectChildren     User[]  @relation("IceconnectHierarchy")

  onboardingRequestsCreated OnboardingRequest[] @relation("OnboardingRequestCreator")
  onboardingRequestBossFor  OnboardingRequest[] @relation("OnboardingRequestBossUser")
  onboardingPipelineSource  OnboardingPipeline[] @relation("OnboardingPipelineSource")
  onboardingPipelineAsRsm   OnboardingPipeline[] @relation("OnboardingPipelineAssignedRsm")
  onboardingPipelineAsBdm   OnboardingPipeline[] @relation("OnboardingPipelineAssignedBdm")
  onboardingPipelineAsBde   OnboardingPipeline[] @relation("OnboardingPipelineAssignedBde")
  ownershipClaimsRequested  OwnershipClaim[]      @relation("OwnershipClaimRequester")
  ownershipClaimsAsOwner    OwnershipClaim[]      @relation("OwnershipClaimCurrentOwner")
  usageFlagsHandled         UsageFlag[]           @relation("UsageFlagHandledBy")
  usageCapacityNotifications UsageCapacityNotification[]

  @@index([email])
  @@index([parentId])
  @@index([employeeSystem, iceconnectEmployeeRole])
}

/// ICECONNECT BDE daily Nexa mission (prospecting goal).
enum BdeMissionStatus {
  PENDING
  COMPLETED
}


/// BDE-initiated company onboarding pipeline (BDE → Sales → Tech → Boss account).
enum OnboardingRequestDashboardType {
  SOLAR
  BUILDER
  ACADEMY
  CUSTOM
}

enum OnboardingRequestStatus {
  PENDING
  SALES_REVIEW
  TECH_QUEUE
  COMPLETED
}

enum OnboardingPipelineSourceType {
  INBOUND
  BDE
  BDM
  RSM
}

enum OnboardingPipelineStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  SENT_TO_TECH
  COMPLETED
}

enum LeadOwnershipRole {
  BDE
  BDM
  RSM
}

enum LeadSourceType {
  INBOUND
  BDE
  BDM
  RSM
}

enum OwnershipClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

model OnboardingRequest {
  id              String                         @id @default(cuid())
  createdByUserId String
  companyName     String
  bossEmail       String
  dashboardType   OnboardingRequestDashboardType
  /// Build target; mirrors {@link dashboardType} (e.g. solar → solar).
  template        OnboardingRequestDashboardType
  status          OnboardingRequestStatus        @default(PENDING)
  notes           String?                        @db.Text
  /// Sales review: team structure, roles, departments, expected users (JSON).
  salesQuestionnaire Json?
  techTemplate       String?
  techNotes          String?                      @db.Text
  bossUserId         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy User  @relation("OnboardingRequestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  bossUser  User? @relation("OnboardingRequestBossUser", fields: [bossUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([status])
  @@map("onboarding_requests")
}

model OnboardingPipeline {
