// =============================================================================
// INTERNAL WALLET — BGOS staff earnings ledger (id: bgos_wallet_core_v1)
//
// Entirely separate from the MicroFranchisePartner Wallet.
// All internal-staff earnings flow through InternalWalletTransaction.
// Commission breakdowns are stored in SalesHierarchyEarning (never surfaced
// to the wallet UI); the wallet only surfaces aggregated balances + type labels.
// =============================================================================

enum InternalWalletTxType {
  DIRECT
  RECURRING
  BONUS
  REWARD
  ADJUSTMENT
  WITHDRAWAL
}

enum InternalWalletTxStatus {
  PENDING
  APPROVED
  CREDITED
  REJECTED
}

/// Per-user balance ledger for internal BGOS sales staff.
model InternalWallet {
  userId              String    @id
  /// Sum of all credited + bonus amounts (lifetime).
  totalBalance        Float     @default(0)
  /// Available for withdrawal (approved + credited, excluding bonuses).
  withdrawableBalance Float     @default(0)
  /// Bonuses and rewards credited separately.
  bonusBalance        Float     @default(0)
  /// Earnings awaiting approval validation.
  pendingBalance      Float     @default(0)
  /// Timestamp of BDE-agreement acceptance — required before any withdrawal.
  agreementAcceptedAt DateTime?
  updatedAt           DateTime  @updatedAt

  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions InternalWalletTransaction[]

  @@map("internal_wallet")
}


/// Individual credit/debit events on an InternalWallet.
model InternalWalletTransaction {
  id          String                 @id @default(cuid())
  userId      String
  type        InternalWalletTxType
  amount      Float
  status      InternalWalletTxStatus @default(PENDING)
  /// Links back to SalesHierarchyEarning.id or another source record.
  referenceId String?
  note        String?
  createdAt   DateTime               @default(now())

  wallet InternalWallet @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@map("internal_wallet_transaction")
}

// =============================================================================
// INTERNAL REWARDS & GAMIFICATION  (id: bgos_rewards_gamification_v1)
