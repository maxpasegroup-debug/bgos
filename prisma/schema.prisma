/// Dynamic sections JSON — rendered by form engine (category + plan tier).
model OnboardingFormTemplate {
  id        String                     @id @default(cuid())
  companyId String
  category  String
  planTier  OnboardingWorkflowPlanTier
  sections  Json
  isActive  Boolean                    @default(true)
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  company     Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submissions OnboardingSubmission[]

  @@unique([companyId, category, planTier])
  @@index([companyId])
  @@index([category, planTier])
}

/// One workflow per linked lead (optional); token access for client fill.
model OnboardingSubmission {
  id                 String                     @id @default(cuid())
  companyId          String
  leadId             String?                    @unique
  templateId         String
  category           String
  planTier           OnboardingWorkflowPlanTier
  filledByUserId     String?
  clientAccessToken  String                     @unique
  status             OnboardingSubmissionStatus @default(DRAFT)
  data               Json                       @default("{}")
  completionPercent  Int                        @default(0)
  assignedTechUserId String?
  deliveryPdfPath    String?
  salesDeliveredAt   DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  company      Company                       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template     OnboardingFormTemplate        @relation(fields: [templateId], references: [id], onDelete: Restrict)
  lead         Lead?                         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  filledBy     User?                         @relation("OnboardingFilledBy", fields: [filledByUserId], references: [id], onDelete: SetNull)
  techAssignee User?                         @relation("OnboardingTechAssignee", fields: [assignedTechUserId], references: [id], onDelete: SetNull)
