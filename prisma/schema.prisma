// BGOS + ICECONNECT — multi-company schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  TELECALLER
  ENGINEER
  INSTALLER
  ACCOUNTS
  SERVICE
  MANAGER
}

enum CompanyPlan {
  BASIC
  PRO
}

enum CompanyIndustry {
  SOLAR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  SITE_VISIT_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum PaymentStatus {
  PAID
  PENDING
}

enum ServiceTicketStatus {
  OPEN
  RESOLVED
}

model Company {
  id         String          @id @default(cuid())
  name       String
  industry   CompanyIndustry @default(SOLAR)
  plan       CompanyPlan     @default(BASIC)
  ownerId    String
  createdAt  DateTime        @default(now())

  logoUrl         String?
  primaryColor    String?
  secondaryColor  String?

  /** Public / document-facing profile (quotations, invoices, PDFs). */
  companyEmail    String?
  companyPhone    String?
  billingAddress  String? @db.Text
  gstNumber       String?
  bankDetails     String? @db.Text

  businessTemplate String?
  dashboardConfig  Json?

  owner         User            @relation("OwnedCompany", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships   UserCompany[]
  leads         Lead[]
  deals         Deal[]
  tasks         Task[]
  installations Installation[]
  payments        Payment[]
  quotations      Quotation[]
  moneyInvoices   Invoice[]
  expenses        Expense[]
  invoicePayments InvoicePayment[]
  activityLogs    ActivityLog[]
  serviceTickets ServiceTicket[]
  automations   Automation[]

  @@index([name])
  @@index([ownerId])
}

/// Membership: `role` is company-level (ADMIN vs EMPLOYEE); `jobRole` is operational RBAC (TELECALLER, ENGINEER, …).
model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String
  jobRole   UserRole
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  mobile    String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  /** Set when the boss completes onboarding step 2 (NEXA activation). Invited employees get this on create. */
  workspaceActivatedAt DateTime?

  companiesOwned       Company[]        @relation("OwnedCompany")
  memberships          UserCompany[]
  assignedLeads        Lead[]         @relation("LeadAssignee")
  tasks                Task[]
  activityLogs         ActivityLog[]
  assignedInstallations Installation[] @relation("InstallationAssignee")
  assignedServiceTickets ServiceTicket[] @relation("TicketAssignee")

  @@index([email])
}

model Lead {
  id         String      @id @default(cuid())
  name       String
  phone      String
  email      String?
  source     String?
  status     LeadStatus  @default(NEW)
  value      Float?
  companyId  String
  assignedTo String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee User?   @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  deals       Deal[]
  tasks       Task[]
  quotations  Quotation[]
  invoices    Invoice[]
  siteReport  String? @db.Text

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
  @@index([phone])
}

model Deal {
  id        String     @id @default(cuid())
  leadId    String
  companyId String
  value     Float
  status    DealStatus
  stage     String?
  createdAt DateTime   @default(now())

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([companyId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  userId      String?
  leadId      String?
  companyId   String
  priority    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status, priority])
}

model Automation {
  id        String @id @default(cuid())
  name      String
  trigger   String
  action    String
  config    Json
  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, trigger])
}

model Installation {
  id            String    @id @default(cuid())
  status        String
  scheduledDate DateTime?
  companyId     String
  assignedTo    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee User?   @relation("InstallationAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
}

model Payment {
  id        String        @id @default(cuid())
  amount    Float
  status    PaymentStatus
  companyId String
  createdAt DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

/// Customer quotation (money layer). Numbers are per-company unique (e.g. Q-0001).
model Quotation {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String?
  /** Snapshot / override when not using a lead or for PDF display. */
  customerName     String?
  customerPhone    String?
  quotationNumber  String
  status           String
  totalAmount      Float
  items            Json
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Invoice linked optionally to quotation + lead.
model Invoice {
  id            String    @id @default(cuid())
  companyId     String
  quotationId   String?
  leadId        String?
  invoiceNumber String
  status        String
  totalAmount   Float
  paidAmount    Float     @default(0)
  dueDate       DateTime?
  items         Json
  createdAt     DateTime  @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotation   Quotation?       @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  lead        Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  payments    InvoicePayment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([quotationId])
  @@index([leadId])
  @@index([status])
}

/// Payment allocated to an invoice (distinct from legacy `Payment` register rows).
model InvoicePayment {
  id        String   @id @default(cuid())
  companyId String
  invoiceId String
  amount    Float
  method    String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@index([date])
}

model Expense {
  id        String   @id @default(cuid())
  companyId String
  title     String
  amount    Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
}

model ServiceTicket {
  id          String              @id @default(cuid())
  title       String
  description String?             @db.Text
  status      ServiceTicketStatus @default(OPEN)
  companyId   String
  assignedTo  String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  companyId String?
  userId    String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}
