  title       String
  description String?             @db.Text
  status      ServiceTicketStatus @default(OPEN)
  companyId   String
  leadId      String?
  assignedTo  String?
  issue       String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

