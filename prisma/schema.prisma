// BGOS + ICECONNECT — multi-company schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES_HEAD
  SALES_EXECUTIVE
  /** Field sales / dialling — same workspace capabilities as sales executive. */
  TELECALLER
  CHANNEL_PARTNER
  OPERATIONS_HEAD
  SITE_ENGINEER
  PRO
  INSTALLATION_TEAM
  SERVICE_TEAM
  INVENTORY_MANAGER
  ACCOUNTANT
  LCO
  HR_MANAGER
}

enum CompanyPlan {
  BASIC
  PRO
  ENTERPRISE
}

/** Derived billing/trial state; kept in sync on writes and subscription reads. */
enum CompanySubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
}

enum CompanyIndustry {
  SOLAR
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  SITE_VISIT_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  /** Quotation approved — booked, awaiting payment. */
  PROPOSAL_WON
  WON
  LOST
}

enum DealStatus {
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum PaymentStatus {
  PAID
  PENDING
}

enum ServiceTicketStatus {
  OPEN
  RESOLVED
}

model Company {
  id         String          @id @default(cuid())
  name       String
  industry   CompanyIndustry @default(SOLAR)
  /** Subscription tier; remains {@link CompanyPlan} in DB (not a free-form string). */
  plan       CompanyPlan     @default(BASIC)
  ownerId    String
  createdAt  DateTime        @default(now())

  /** Clock start for the 15-day BASIC trial; null = pre-trial schema / grandfathered. */
  trialStartDate DateTime?
  /** Exclusive wall-clock end: expired when `now >= trialEndDate` for BASIC. */
  trialEndDate   DateTime?
  isTrialActive  Boolean   @default(true)

  /**
   * Subscription status (trial / active paid / expired trial).
   * Canonical plan tier remains {@link CompanyPlan} in `plan`. Trial end instant remains `trialEndDate`
   * (APIs may expose it as `trialEndsAt`).
   */
  subscriptionStatus CompanySubscriptionStatus @default(TRIAL)
  /** Wall-clock start of the current paid Razorpay/Stripe period (optional). */
  subscriptionPeriodStart DateTime?
  /** Paid access valid strictly before this instant (Razorpay monthly renewals extend this). */
  subscriptionPeriodEnd   DateTime?

  logoUrl         String?
  primaryColor    String?
  secondaryColor  String?

  /** Public / document-facing profile (quotations, invoices, PDFs). */
  companyEmail    String?
  companyPhone    String?
  billingAddress  String? @db.Text
  gstNumber       String?
  bankDetails     String? @db.Text

  businessTemplate String?
  dashboardConfig  Json?

  owner         User            @relation("OwnedCompany", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships   UserCompany[]
  leads         Lead[]
  deals         Deal[]
  tasks         Task[]
  installations Installation[]
  payments        Payment[]
  quotations      Quotation[]
  moneyInvoices   Invoice[]
  expenses        Expense[]
  invoicePayments InvoicePayment[]
  activityLogs    ActivityLog[]
  serviceTickets ServiceTicket[]
  automations   Automation[]
  documents     Document[]
  leaveRequests LeaveRequest[]
  attendances   Attendance[]
  salaries      Salary[]
  products      Product[]
  stocks        Stock[]
  stockLogs     StockLog[]
  channelPartners ChannelPartner[]
  commissions    Commission[]
  siteVisits     SiteVisit[]
  approvals      Approval[]
  growthPlan     CompanyGrowthPlan?
  employeePips   EmployeePip[]
  lcoLoans       LcoLoan[]
  customerUsers  CustomerPortalUser[]
  complaints     CustomerComplaint[]
  razorpayPayments RazorpayPayment[]

  @@index([name])
  @@index([ownerId])
}

/** Boss monthly targets on Home — drives projections (1Y / multi-year copy). */
model CompanyGrowthPlan {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  targetRevenueOneMonth Float    @default(0)
  targetLeadsOneMonth   Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/** Performance improvement plan for an employee. */
model EmployeePip {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  goal        String   @db.Text
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, userId, isCompleted])
}

/** Loan compliance tracker linked to customer lead. */
model LcoLoan {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  loanAmount Float
  /// PENDING | APPROVED | REJECTED
  status     String   @default("PENDING")
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/** Customer login account for ICECONNECT customer portal (one per customer lead). */
model CustomerPortalUser {
  id           String   @id @default(cuid())
  companyId    String
  leadId       String   @unique
  mobile       String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([mobile])
  @@unique([companyId, mobile])
}

/** Customer complaints linked to a customer lead. */
model CustomerComplaint {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String
  description String   @db.Text
  /// PENDING | RESOLVED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Processed billing webhook deliveries (e.g. Stripe `evt_*`) — prevents double-applying upgrades.
model BillingWebhookEvent {
  id         String   @id @default(cuid())
  provider   String   @default("stripe")
  externalId String   @unique
  eventType  String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

/// Razorpay Checkout payments (verify path + idempotency).
model RazorpayPayment {
  id                String      @id @default(cuid())
  companyId         String
  userId            String
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique
  plan              CompanyPlan
  amount            Int
  currency          String      @default("INR")
  status            String
  createdAt         DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

/// Membership: `role` is company-level (ADMIN vs EMPLOYEE); `jobRole` is operational RBAC (solar CRM role enum).
model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String
  jobRole   UserRole
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  mobile    String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  /** Set when the boss completes onboarding step 2 (NEXA activation). Invited employees get this on create. */
  workspaceActivatedAt DateTime?

  companiesOwned       Company[]        @relation("OwnedCompany")
  memberships          UserCompany[]
  assignedLeads        Lead[]         @relation("LeadAssignee")
  leadsCreated         Lead[]         @relation("LeadCreator")
  tasks                Task[]
  activityLogs         ActivityLog[]
  assignedInstallations Installation[] @relation("InstallationAssignee")
  assignedServiceTickets ServiceTicket[] @relation("TicketAssignee")
  leaveRequests          LeaveRequest[]
  attendances            Attendance[]
  salaries               Salary[]
  pips                   EmployeePip[]
  createdChannelPartners ChannelPartner[] @relation("PartnerCreator")
  assignedSiteVisits     SiteVisit[] @relation("SiteVisitAssignee")
  documentsUploaded      Document[]
  razorpayPayments       RazorpayPayment[]

  @@index([email])
}

model Lead {
  id         String      @id @default(cuid())
  name       String
  phone      String
  email      String?
  source     String?
  status     LeadStatus  @default(NEW)
  value      Float?
  companyId       String
  assignedTo      String?
  /** User who created the lead in BGOS (audit / “boss vs team” views). */
  createdByUserId String?
  partnerId       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee User?   @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator  User?   @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  partner  ChannelPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  deals       Deal[]
  tasks       Task[]
  quotations  Quotation[]
  invoices    Invoice[]
  documents   Document[]
  commissions Commission[]
  siteVisits  SiteVisit[]
  approvals   Approval[]
  lcoLoans    LcoLoan[]
  customerUser CustomerPortalUser?
  complaints   CustomerComplaint[]
  installations Installation[]
  serviceTickets ServiceTicket[]
  siteReport  String? @db.Text

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
  @@index([createdByUserId])
  @@index([partnerId])
  @@index([phone])
}

model Deal {
  id        String     @id @default(cuid())
  leadId    String
  companyId String
  value     Float
  status    DealStatus
  stage     String?
  createdAt DateTime   @default(now())

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([companyId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  userId      String?
  leadId      String?
  companyId   String
  priority    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status, priority])
}

model Automation {
  id        String @id @default(cuid())
  name      String
  trigger   String
  action    String
  config    Json
  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, trigger])
}

model Installation {
  id            String    @id @default(cuid())
  status        String
  scheduledDate DateTime?
  companyId     String
  leadId        String?
  assignedTo    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee User?   @relation("InstallationAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@unique([companyId, leadId])
  @@index([status])
  @@index([leadId])
  @@index([assignedTo])
}

model Payment {
  id        String        @id @default(cuid())
  amount    Float
  status    PaymentStatus
  companyId String
  createdAt DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

/// Customer quotation (money layer). Numbers are per-company unique (e.g. Q-0001).
model Quotation {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String?
  /** Snapshot / override when not using a lead or for PDF display. */
  customerName     String?
  customerPhone    String?
  quotationNumber  String
  status           String
  totalAmount      Float
  items            Json
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Invoice linked optionally to quotation + lead.
model Invoice {
  id            String    @id @default(cuid())
  companyId     String
  quotationId   String?
  leadId        String?
  invoiceNumber String
  status        String
  totalAmount   Float
  paidAmount    Float     @default(0)
  dueDate       DateTime?
  items         Json
  createdAt     DateTime  @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotation   Quotation?       @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  lead        Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  payments    InvoicePayment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([quotationId])
  @@index([leadId])
  @@index([status])
}

/// Payment allocated to an invoice (distinct from legacy `Payment` register rows).
model InvoicePayment {
  id        String   @id @default(cuid())
  companyId String
  invoiceId String
  amount    Float
  method    String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@index([date])
}

model Expense {
  id        String   @id @default(cuid())
  companyId String
  title     String
  amount    Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
}

model ServiceTicket {
  id          String              @id @default(cuid())
  title       String
  description String?             @db.Text
  status      ServiceTicketStatus @default(OPEN)
  companyId   String
  leadId      String?
  assignedTo  String?
  issue       String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([leadId])
  @@index([assignedTo])
}

model SiteVisit {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  assignedTo String
  /// SCHEDULED | COMPLETED
  status     String
  report     Json?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User   @relation("SiteVisitAssignee", fields: [assignedTo], references: [id], onDelete: Restrict)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([assignedTo])
  @@index([status])
}

model Approval {
  id        String   @id @default(cuid())
  companyId String
  leadId    String
  /// PENDING | APPROVED | REJECTED
  status    String
  notes     String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([status])
}

/// Company file storage: agreements, approvals, site reports, customer docs.
model Document {
  id        String   @id @default(cuid())
  companyId String
  leadId    String?
  customerId String?
  /// AGREEMENT | APPROVAL | REPORT | OTHER
  type      String
  /// Storage key: `{companyId}/documents/{yyyy}/{mm}/{unique}-{safeName}` (local disk or S3 object key).
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())
  /// Who uploaded (nullable for legacy rows before audit columns).
  uploadedByUserId String?
  /// `UserRole` at upload time (membership can change later).
  uploadedByRole   String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  uploader User?  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, uploadedByUserId])
  @@index([leadId])
  @@index([customerId])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  fromDate  DateTime
  toDate    DateTime
  reason    String
  /// PENDING | APPROVED | REJECTED
  status    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, status])
}

model Attendance {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, date])
  @@index([companyId])
  @@index([userId])
}

model Salary {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  amount    Float
  month     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, month])
  @@index([companyId])
  @@index([userId])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  name      String
  /// Panel | Inverter | Battery | Accessories
  category  String
  unit      String
  minStockLevel Float @default(5)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks  Stock[]
  logs    StockLog[]

  @@index([companyId])
  @@index([companyId, category])
}

model Stock {
  id        String   @id @default(cuid())
  companyId String
  productId String
  quantity  Float
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId])
  @@index([companyId])
}

model StockLog {
  id        String   @id @default(cuid())
  companyId String
  productId String
  /// IN | OUT
  type      String
  quantity  Float
  reference String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([companyId, type])
}

model ChannelPartner {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  phone           String
  createdByUserId String
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator User @relation("PartnerCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  leads   Lead[]
  commissions Commission[]

  @@index([companyId])
  @@index([createdByUserId])
}

model Commission {
  id        String   @id @default(cuid())
  companyId String
  partnerId String
  leadId    String
  amount    Float
  /// DIRECT | REFERRAL
  type      String
  /// PENDING | PAID
  status    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner ChannelPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  lead    Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([partnerId])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  companyId String?
  userId    String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}
