/**
 * Online micro-franchise applicant pipeline (APPLICATION → … → APPROVED).
 */

/**
 * Commission template for micro-franchise offers (boss-managed).
 */

/**
 * Activated micro-franchise partner (ICECONNECT login + referral phone as ID).
 */




/**
 * Monthly sales target + salary for ICECONNECT executives (internal org).
 */

model Lead {
  id              String     @id @default(cuid())
  name            String
  phone           String
  email           String?
  source          String?
  status          LeadStatus @default(NEW)
  value           Float?
  companyId       String
  assignedTo      String?
  /**
   * User who created the lead in BGOS (audit / “boss vs team” views).
   */
  createdByUserId String?
  ownerUserId     String?            @map("owner_user_id")
  ownerRole       LeadOwnershipRole? @map("owner_role")
  sourceType      LeadSourceType?    @map("source_type")
  sourceUserId    String?            @map("source_user_id")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee       User?               @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User?               @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  owner          User?               @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sourceUser     User?               @relation("LeadSourceUser", fields: [sourceUserId], references: [id], onDelete: SetNull)
  deals          Deal[]
  tasks          Task[]
  quotations     Quotation[]
  invoices       Invoice[]
  documents      Document[]
  siteVisits     SiteVisit[]
  approvals      Approval[]
  installations  Installation[]
  projects       Project[]
  serviceJobs    ServiceJob[]
  serviceTickets ServiceTicket[]
  siteReport     String?             @db.Text

  /**
   * Customer / prospect company name (internal sales).
   */
  leadCompanyName                  String?
  businessType                     String?
  internalSalesNotes               String?                           @db.Text
  internalSalesStage               InternalSalesStage?
  internalCallStatus               InternalCallStatus?
  lastContactedAt                  DateTime?
  nextFollowUpAt                   DateTime?
  internalTechStage                InternalTechStage?
  internalOnboardingApprovalStatus InternalOnboardingApprovalStatus?
  /**
   * SLA / escalation: last time sales or tech stage moved.
   */
  internalStageUpdatedAt           DateTime?

  /**
   * Sales-selected tier before onboarding form is opened (internal org).
   */
  onboardingType LeadOnboardingType?

  /**
   * ICECONNECT executive metro (internal org).
   */
  iceconnectLocation     String?
  iceconnectMetroStage   IceconnectMetroStage?
  iceconnectCustomerPlan IceconnectCustomerPlan?
  iceconnectSubscribedAt DateTime?
  /**
   * Nexa intelligence state for metro pipeline automation.
   */
  currentStage           String?
  lastActivityAt         DateTime?
  nextActionDue          DateTime?
  activityCount          Int                     @default(0)
  responseStatus         LeadResponseStatus      @default(RESPONSIVE)
  confidenceScore        Int                     @default(50)
  nexaPriority           Boolean                 @default(false)
  nexaMovedAt            DateTime?
  nexaMovedReason        String?

  onboardingTasks              OnboardingTask[]
  onboardingWorkflowSubmission OnboardingSubmission?
  onboardingSessions           OnboardingSession[]
  onboardingRecords            Onboarding[]
  ownershipClaims              OwnershipClaim[]
  internalLeadActivities       InternalLeadActivity[]
  nexaSupportTickets           InternalNexaSupportTicket[]

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
  @@index([createdByUserId])
  @@index([ownerUserId, ownerRole])
  @@index([phone])
  @@index([companyId, email])
  @@index([companyId, phone])
  @@index([companyId, assignedTo, iceconnectMetroStage])
}

model OwnershipClaim {
  id             String               @id @default(cuid())
  companyId      String               @map("company_id")
  leadId         String?              @map("lead_id")
  requestedBy    String               @map("requested_by")
  currentOwnerId String?              @map("current_owner_id")
  status         OwnershipClaimStatus @default(PENDING)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  requester    User    @relation("OwnershipClaimRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  currentOwner User?   @relation("OwnershipClaimCurrentOwner", fields: [currentOwnerId], references: [id], onDelete: SetNull)

  @@index([companyId, status, createdAt])
  @@index([leadId, status])
  @@map("ownership_claims")
}

model Onboarding {
  id        String           @id @default(cuid())
  leadId    String
  companyId String?
  status    OnboardingStatus @default(IN_PROGRESS)
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  meta      Json?

  lead    Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creator User     @relation("OnboardingCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([leadId, status])
  @@index([createdBy, createdAt])
  @@index([companyId])
}

model Deal {
