/// Solar project lifecycle (planning -> execution -> closure), company-scoped.
model Project {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String?
  name        String
  status      String   @default("PLANNED")
  startDate   DateTime?
  endDate     DateTime?
  description String?  @db.Text
