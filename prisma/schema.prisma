  companyId String
  invoiceId String
  amount    Float
  method    String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@index([date])
}

model Expense {
  id        String   @id @default(cuid())
  companyId String
  title     String
  amount    Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
}

model ServiceTicket {
