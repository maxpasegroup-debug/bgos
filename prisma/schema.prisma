/// Tech-side status mirror (linked 1:1 to submission).
model OnboardingSubmissionTechTask {
  id           String                   @id @default(cuid())
  submissionId String                   @unique
  status       OnboardingTechTaskStatus @default(NEW)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  submission OnboardingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status])
}

