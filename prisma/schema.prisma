// BGOS + ICECONNECT — multi-company schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  SALES_HEAD
  SALES_EXECUTIVE
  /** Field sales / dialling — same workspace capabilities as sales executive. */
  TELECALLER
  /** BGOS Internal tech lead (delivery pipeline). */
  TECH_HEAD
  /** BGOS Internal tech execution (delivery pipeline). */
  TECH_EXECUTIVE
  CHANNEL_PARTNER
  OPERATIONS_HEAD
  SITE_ENGINEER
  PRO
  INSTALLATION_TEAM
  SERVICE_TEAM
  INVENTORY_MANAGER
  ACCOUNTANT
  LCO
  HR_MANAGER
  /** Online micro-franchise partner (ICECONNECT workspace, referral + wallet). */
  MICRO_FRANCHISE
}

enum CompanyPlan {
  BASIC
  PRO
  ENTERPRISE
}

/** Derived billing/trial state; kept in sync on writes and subscription reads. */
enum CompanySubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  /** Custom-build workspaces: selected plan but initial subscription payment not completed yet. */
  PAYMENT_PENDING
}

enum CompanyIndustry {
  SOLAR
  CUSTOM
}

/** Product line: solar CRM vs paid custom dashboard build. */
enum CompanyBusinessType {
  SOLAR
  CUSTOM
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT_SCHEDULED
  SITE_VISIT_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  /** Quotation approved — booked, awaiting payment. */
  PROPOSAL_WON
  WON
  LOST
}

/** BGOS Internal sales metro pipeline (company with `internalSalesOrg`). Linear order — no skips. */
enum InternalSalesStage {
  LEAD_ADDED
  INTRO_CALL
  DEMO_ORIENTATION
  FOLLOW_UP
  INTERESTED
  ONBOARDING_FORM_FILLED
  BOSS_APPROVAL_PENDING
  SENT_TO_TECH
  TECH_READY
  DELIVERED
  CLIENT_LIVE
  CLOSED_LOST
}

/** Tech delivery metro (after Sent to Tech). */
enum InternalTechStage {
  ONBOARDING_RECEIVED
  DATA_VERIFIED
  DASHBOARD_SETUP
  EMPLOYEE_SETUP
  SYSTEM_TESTING
  READY_FOR_DELIVERY
}

enum InternalOnboardingApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InternalCallStatus {
  NOT_CALLED
  CALLED
  NO_ANSWER
  INTERESTED
  NOT_INTERESTED
}

/** ICECONNECT sales executive metro pipeline (internal org). SUBSCRIPTION = converted customer. */
enum IceconnectMetroStage {
  LEAD_CREATED
  INTRO_CALL
  DEMO_DONE
  FOLLOW_UP
  ONBOARDING
  PAYMENT_DONE
  SUBSCRIPTION
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
}

/** Plan tier for executive targets and converted ICECONNECT customers. */
enum IceconnectCustomerPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

/** Category for a single active user manual PDF per company. */
enum UserManualCategory {
  SALES
  OPERATIONS
  HR
  ACCOUNTS
  SALES_BOOSTER
}

/** Internal CRM: onboarding tier chosen by sales before the client form opens. */
enum LeadOnboardingType {
  BASIC
  PRO
  ENTERPRISE
}

/** Tech queue sort: Enterprise first, then Pro, then Basic. */
enum TechQueuePriority {
  CRITICAL
  HIGH
  LOW
}

/**
 * Tech delivery steps (no skipping). Synced to {@link InternalTechStage} on the lead when possible.
 */
enum TechPipelineStage {
  RECEIVED
  SETUP_DASHBOARD
  ADD_EMPLOYEES
  CONFIGURE_MODULES
  TESTING
  READY
}

/** Tech onboarding queue for internal sales → delivery. */
enum OnboardingTaskStatus {
  NEW
  DATA_RECEIVED
  SETUP_STARTED
  SETUP_COMPLETED
  DELIVERED
}

enum DealStatus {
  WON
  LOST
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum PaymentStatus {
  PAID
  PENDING
}

enum ServiceTicketStatus {
  OPEN
  RESOLVED
}

/** BGOS onboarding workflow templates (category + tier). */
enum OnboardingWorkflowPlanTier {
  BASIC
  PRO
  ENTERPRISE
}

enum OnboardingSubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_INFO
  READY
  DELIVERED
}

enum OnboardingTechTaskStatus {
  NEW
  IN_PROGRESS
  WAITING_INFO
  READY
  DELIVERED
}

model Company {
  id         String          @id @default(cuid())
  name       String
  industry   CompanyIndustry @default(SOLAR)
  /** Solar (default trial path) vs custom paid build — see {@link CompanyBusinessType}. */
  businessType CompanyBusinessType @default(SOLAR)
  /** Subscription tier; remains {@link CompanyPlan} in DB (not a free-form string). */
  plan       CompanyPlan     @default(BASIC)
  ownerId    String
  createdAt  DateTime        @default(now())

  /** Clock start for the 15-day BASIC trial; null = pre-trial schema / grandfathered. */
  trialStartDate DateTime?
  /** Exclusive wall-clock end: expired when `now >= trialEndDate` for BASIC. */
  trialEndDate   DateTime?
  isTrialActive  Boolean   @default(true)

  /**
   * Subscription status (trial / active paid / expired trial).
   * Canonical plan tier remains {@link CompanyPlan} in `plan`. Trial end instant remains `trialEndDate`
   * (APIs may expose it as `trialEndsAt`).
   */
  subscriptionStatus CompanySubscriptionStatus @default(TRIAL)
  /** Wall-clock start of the current paid Razorpay/Stripe period (optional). */
  subscriptionPeriodStart DateTime?
  /** Paid access valid strictly before this instant (Razorpay monthly renewals extend this). */
  subscriptionPeriodEnd   DateTime?

  logoUrl         String?
  primaryColor    String?
  secondaryColor  String?

  /** Public / document-facing profile (quotations, invoices, PDFs). */
  companyEmail    String?
  companyPhone    String?
  billingAddress  String? @db.Text
  gstNumber       String?
  bankDetails     String? @db.Text

  businessTemplate String?
  dashboardConfig  Json?

  /** True for the dedicated BGOS internal sales tenant (“BGOS Internal”). */
  internalSalesOrg Boolean @default(false)
  /** Optional default assignee for public / anonymous lead capture. */
  internalSalesDefaultAssigneeId String?
  /** Round-robin: last tech user id assigned to an onboarding workflow submission. */
  internalWorkflowLastTechUserId String?

  /** Set when the customer completes the custom requirements form (custom businessType only). */
  customOnboardingSubmittedAt DateTime?
  /**
   * After internal sales confirms final payment, tech may contact the client and start build.
   * Until then: internal planning only (no client comms).
   */
  customBuildClientContactAllowed Boolean @default(false)
  customFinalPaymentConfirmedAt   DateTime?

  /** Platform (super boss): hide archived tenants from the client directory. */
  archivedAt DateTime?
  /** Optional referral phone captured at launch. */
  referralPhone String?
  /** Sales-launch channel partner (cross-company referral tracking). */
  launchChannelPartnerId String?
  /** Micro-franchise partner linked by referral phone (takes precedence over channel partner when matched). */
  microFranchisePartnerId String?

  owner         User            @relation("OwnedCompany", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships   UserCompany[]
  leads         Lead[]
  deals         Deal[]
  tasks         Task[]
  installations Installation[]
  payments        Payment[]
  quotations      Quotation[]
  moneyInvoices   Invoice[]
  expenses        Expense[]
  invoicePayments InvoicePayment[]
  activityLogs    ActivityLog[]
  serviceTickets ServiceTicket[]
  automations   Automation[]
  nexaActions   NexaAction[]
  documents     Document[]
  leaveRequests LeaveRequest[]
  attendances   Attendance[]
  salaries      Salary[]
  products      Product[]
  stocks        Stock[]
  stockLogs     StockLog[]
  channelPartners ChannelPartner[]
  commissions    Commission[]
  siteVisits     SiteVisit[]
  approvals      Approval[]
  growthPlan     CompanyGrowthPlan?
  employeePips   EmployeePip[]
  lcoLoans       LcoLoan[]
  customerUsers  CustomerPortalUser[]
  complaints     CustomerComplaint[]
  razorpayPayments RazorpayPayment[]
  onboardingTasks           OnboardingTask[]
  internalLeadActivities    InternalLeadActivity[]
  internalInAppNotifications InternalInAppNotification[]
  internalEmployeeDailyTargets InternalEmployeeDailyTarget[]
  internalNexaSupportTickets InternalNexaSupportTicket[]
  userManuals                UserManual[]
  salesExecutiveMonthlyTargets SalesExecutiveMonthlyTarget[]
  onboardingFormTemplates      OnboardingFormTemplate[]
  onboardingSubmissions        OnboardingSubmission[]
  onboardingSessions           OnboardingSession[]
  onboardingRecords            Onboarding[]
  launchChannelPartner         LaunchChannelPartner? @relation("LaunchPartnerCompany", fields: [launchChannelPartnerId], references: [id], onDelete: SetNull)
  microFranchisePartner        MicroFranchisePartner? @relation(fields: [microFranchisePartnerId], references: [id], onDelete: SetNull)
  microFranchiseCommissionTxs    CommissionTransaction[]
  techRequests                 TechRequest[]

  @@index([name])
  @@index([ownerId])
  @@index([launchChannelPartnerId])
  @@index([microFranchisePartnerId])
}

/** Boss monthly targets on Home — drives projections (1Y / multi-year copy). */
model CompanyGrowthPlan {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  targetRevenueOneMonth Float    @default(0)
  targetLeadsOneMonth   Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

/** Performance improvement plan for an employee. */
model EmployeePip {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  goal        String   @db.Text
  progress    Int      @default(0)
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, userId, isCompleted])
}

/** Loan compliance tracker linked to customer lead. */
model LcoLoan {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  loanAmount Float
  /// PENDING | APPROVED | REJECTED
  status     String   @default("PENDING")
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/** Customer login account for ICECONNECT customer portal (one per customer lead). */
model CustomerPortalUser {
  id           String   @id @default(cuid())
  companyId    String
  leadId       String   @unique
  mobile       String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([mobile])
  @@unique([companyId, mobile])
}

/** Customer complaints linked to a customer lead. */
model CustomerComplaint {
  id          String   @id @default(cuid())
  companyId   String
  leadId      String
  description String   @db.Text
  /// PENDING | RESOLVED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Processed billing webhook deliveries (e.g. Stripe `evt_*`) — prevents double-applying upgrades.
model BillingWebhookEvent {
  id         String   @id @default(cuid())
  provider   String   @default("stripe")
  externalId String   @unique
  eventType  String
  receivedAt DateTime @default(now())

  @@index([receivedAt])
}

/// Razorpay Checkout payments (verify path + idempotency).
model RazorpayPayment {
  id                String      @id @default(cuid())
  companyId         String
  userId            String
  razorpayOrderId   String      @unique
  razorpayPaymentId String?     @unique
  plan              CompanyPlan
  amount            Int
  currency          String      @default("INR")
  status            String
  createdAt         DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
}

/// Membership: `role` is company-level (ADMIN vs EMPLOYEE); `jobRole` is operational RBAC (solar CRM role enum).
model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String
  jobRole   UserRole
  dashboardAssigned String?
  /// READY | PENDING_BUILD | IN_PROGRESS | LIVE
  status    String   @default("READY")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model User {
  id        String    @id @default(cuid())
  name      String
  /** Globally unique login identity (boss, employees, ICECONNECT). */
  email     String    @unique
  password  String
  mobile    String?   @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  /** Set when the boss completes onboarding step 2 (NEXA activation). Invited employees get this on create. */
  workspaceActivatedAt DateTime?
  /** Force one-time password reset on first successful login. */
  firstLogin Boolean @default(false)
  /** Hard gate for credentials minted during onboarding/import. */
  forcePasswordReset Boolean @default(false)
  /** Updated on every successful authentication. */
  lastLogin DateTime?

  companiesOwned       Company[]        @relation("OwnedCompany")
  memberships          UserCompany[]
  assignedLeads        Lead[]         @relation("LeadAssignee")
  leadsCreated         Lead[]         @relation("LeadCreator")
  tasks                Task[]
  activityLogs         ActivityLog[]
  assignedInstallations Installation[] @relation("InstallationAssignee")
  assignedServiceTickets ServiceTicket[] @relation("TicketAssignee")
  leaveRequests          LeaveRequest[]
  attendances            Attendance[]
  salaries               Salary[]
  pips                   EmployeePip[]
  createdChannelPartners ChannelPartner[] @relation("PartnerCreator")
  assignedSiteVisits     SiteVisit[] @relation("SiteVisitAssignee")
  documentsUploaded      Document[]
  razorpayPayments       RazorpayPayment[]
  onboardingTasksCreated OnboardingTask[] @relation("OnboardingTaskCreator")
  internalLeadActivities InternalLeadActivity[]
  internalInAppNotifications InternalInAppNotification[]
  internalNexaSupportTicketsCreated InternalNexaSupportTicket[] @relation("NexaSupportCreator")
  salesExecutiveMonthlyTargets SalesExecutiveMonthlyTarget[]
  onboardingSubmissionsFilled  OnboardingSubmission[] @relation("OnboardingFilledBy")
  onboardingSubmissionsTech    OnboardingSubmission[] @relation("OnboardingTechAssignee")
  onboardingWorkflowMessages   OnboardingMessage[]
  onboardingSessionsCreated    OnboardingSession[] @relation("OnboardingSessionCreator")
  onboardingRecordsCreated     Onboarding[] @relation("OnboardingCreator")
  nexaActions                  NexaAction[] @relation("NexaActionActor")
  microFranchiseReferrals        MicroFranchiseApplication[] @relation("MicroFranchiseReferrer")
  microFranchiseAssignments      MicroFranchiseApplication[] @relation("MicroFranchiseAssignee")
  microFranchisePartner          MicroFranchisePartner?

  @@index([email])
}

/** Sales-launch referral partner registry (cross-company). */
model LaunchChannelPartner {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  totalRevenue Float    @default(0)
  conversions  Int      @default(0)
  createdAt    DateTime @default(now())
  companies    Company[] @relation("LaunchPartnerCompany")
}

/** Sales launch session used by Nexa chat onboarding flow. */
model OnboardingSession {
  id              String   @id @default(cuid())
  source          String?
  leadId          String?
  partnerId       String?
  companyId       String?
  companyName     String?
  industry        String?
  rawTeamInput    String?
  parsedTeam      Json?
  unknownRoles    Json?
  data            Json?
  currentStep     String?
  status          String   @default("draft")
  createdByUserId String
  createdAt       DateTime @default(now())

  creator User @relation("OnboardingSessionCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  lead    Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([createdByUserId, createdAt])
  @@index([status])
  @@index([leadId])
  @@index([companyId])
}

/** Tech exception queue created from launch unknown roles. */
model TechRequest {
  id          String   @id @default(cuid())
  roleName    String
  description String?
  companyId   String?
  status      String   @default("pending")
  priority    String   @default("HIGH")
  requestedBy String?
  createdAt   DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([companyId])
}

/** Online micro-franchise applicant pipeline (APPLICATION → … → APPROVED). */
model MicroFranchiseApplication {
  id             String   @id @default(cuid())
  name           String
  phone          String
  email          String?
  location       String?
  experience     String?
  /// APPLICATION | REVIEW | TRAINING | MOU | APPROVED | REJECTED
  status         String   @default("APPLICATION")
  referredById   String?
  assignedToId   String?
  /// JSON array: { at: ISO string, body: string, authorEmail?: string }
  notes          Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referredBy User? @relation("MicroFranchiseReferrer", fields: [referredById], references: [id], onDelete: SetNull)
  assignedTo User? @relation("MicroFranchiseAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  partner    MicroFranchisePartner?

  @@index([status, createdAt])
  @@index([referredById])
  @@index([phone])
}

/** Commission template for micro-franchise offers (boss-managed). */
model CommissionPlan {
  id           String   @id @default(cuid())
  name         String
  /// PERCENTAGE | FIXED
  type         String
  value        Float
  recurring    Boolean  @default(false)
  instantBonus Float?
  createdAt    DateTime @default(now())

  partners MicroFranchisePartner[]
}

/** Activated micro-franchise partner (ICECONNECT login + referral phone as ID). */
model MicroFranchisePartner {
  id               String   @id @default(cuid())
  applicationId    String?  @unique
  name             String
  phone            String   @unique
  email            String?
  userId           String   @unique
  commissionPlanId String?
  performanceScore Float    @default(0)
  tier             String   @default("BRONZE")
  lastScoredAt     DateTime?
  createdAt        DateTime @default(now())

  application      MicroFranchiseApplication? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissionPlan   CommissionPlan?            @relation(fields: [commissionPlanId], references: [id], onDelete: SetNull)
  wallet           Wallet?
  companies        Company[]
  commissionTransactions CommissionTransaction[]
  alerts           MicroFranchiseAlert[]

  @@index([commissionPlanId])
}

model MicroFranchiseAlert {
  id        String   @id @default(cuid())
  partnerId String
  /// INACTIVE | GROWTH | RISK
  type      String
  /// LOW | MEDIUM | HIGH
  severity  String   @default("LOW")
  title     String
  message   String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner MicroFranchisePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([status, createdAt])
}

model Wallet {
  id          String   @id @default(cuid())
  partnerId   String   @unique
  balance     Float    @default(0)
  pending     Float    @default(0)
  totalEarned Float    @default(0)
  updatedAt   DateTime @updatedAt

  partner MicroFranchisePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

model CommissionTransaction {
  id         String   @id @default(cuid())
  partnerId  String
  companyId  String
  amount     Float
  /// RECURRING | ONE_TIME
  type       String
  /// PENDING (awaiting boss release) | RELEASED (in partner balance) | PAID_OUT
  status     String   @default("PENDING")
  /// Idempotency: Razorpay payment id when commission sourced from subscription payment.
  paymentRef String?  @unique
  createdAt  DateTime @default(now())

  partner MicroFranchisePartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt])
  @@index([companyId])
  @@index([status])
}

/** Monthly sales target + salary for ICECONNECT executives (internal org). */
model SalesExecutiveMonthlyTarget {
  id           String   @id @default(cuid())
  companyId    String
  userId       String
  periodYear   Int
  periodMonth  Int
  targetCount  Int
  targetPlan   IceconnectCustomerPlan
  /** Monthly salary in INR (eligible portion scales with target progress). */
  salaryRupees Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, periodYear, periodMonth])
  @@index([companyId])
  @@index([userId])
}

model Lead {
  id         String      @id @default(cuid())
  name       String
  phone      String
  email      String?
  source     String?
  status     LeadStatus  @default(NEW)
  value      Float?
  companyId       String
  assignedTo      String?
  /** User who created the lead in BGOS (audit / “boss vs team” views). */
  createdByUserId String?
  partnerId       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignee User?   @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator  User?   @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  partner  ChannelPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  deals       Deal[]
  tasks       Task[]
  quotations  Quotation[]
  invoices    Invoice[]
  documents   Document[]
  commissions Commission[]
  siteVisits  SiteVisit[]
  approvals   Approval[]
  lcoLoans    LcoLoan[]
  customerUser CustomerPortalUser?
  complaints   CustomerComplaint[]
  installations Installation[]
  serviceTickets ServiceTicket[]
  siteReport  String? @db.Text

  /** Customer / prospect company name (internal sales). */
  leadCompanyName    String?
  businessType       String?
  internalSalesNotes String?              @db.Text
  internalSalesStage InternalSalesStage?
  internalCallStatus InternalCallStatus?
  lastContactedAt    DateTime?
  nextFollowUpAt     DateTime?
  internalTechStage                 InternalTechStage?
  internalOnboardingApprovalStatus  InternalOnboardingApprovalStatus?
  /** SLA / escalation: last time sales or tech stage moved. */
  internalStageUpdatedAt            DateTime?

  /** Sales-selected tier before onboarding form is opened (internal org). */
  onboardingType LeadOnboardingType?

  /** ICECONNECT executive metro (internal org). */
  iceconnectLocation         String?
  iceconnectMetroStage      IceconnectMetroStage?
  iceconnectCustomerPlan    IceconnectCustomerPlan?
  iceconnectSubscribedAt    DateTime?

  onboardingTasks                 OnboardingTask[]
  onboardingWorkflowSubmission    OnboardingSubmission?
  onboardingSessions              OnboardingSession[]
  onboardingRecords              Onboarding[]
  internalLeadActivities InternalLeadActivity[]
  nexaSupportTickets     InternalNexaSupportTicket[]

  @@index([companyId])
  @@index([status])
  @@index([assignedTo])
  @@index([createdByUserId])
  @@index([partnerId])
  @@index([phone])
  @@index([companyId, email])
  @@index([companyId, assignedTo, iceconnectMetroStage])
}

model Onboarding {
  id         String           @id @default(cuid())
  leadId     String
  companyId  String?
  status     OnboardingStatus @default(IN_PROGRESS)
  createdBy  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  meta       Json?

  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  creator  User     @relation("OnboardingCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([leadId, status])
  @@index([createdBy, createdAt])
  @@index([companyId])
}

model Deal {
  id        String     @id @default(cuid())
  leadId    String
  companyId String
  value     Float
  status    DealStatus
  stage     String?
  createdAt DateTime   @default(now())

  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([companyId])
  @@index([status])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  userId      String?
  leadId      String?
  companyId   String
  priority    Int        @default(0)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([companyId])
  @@index([status])
  @@index([companyId, status, priority])
}

model Automation {
  id        String @id @default(cuid())
  name      String
  trigger   String
  action    String
  config    Json
  companyId String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, trigger])
}

model NexaAction {
  id         String   @id @default(cuid())
  type       String
  event      String
  target     String
  status     String
  message    String
  metadata   Json?
  executedAt DateTime @default(now())
  companyId  String
  actorUserId String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation("NexaActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, executedAt])
  @@index([companyId, event])
  @@index([status])
}

model Installation {
  id            String    @id @default(cuid())
  status        String
  scheduledDate DateTime?
  companyId     String
  leadId        String?
  assignedTo    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee User?   @relation("InstallationAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@unique([companyId, leadId])
  @@index([status])
  @@index([leadId])
  @@index([assignedTo])
}

model Payment {
  id        String        @id @default(cuid())
  amount    Float
  status    PaymentStatus
  companyId String
  createdAt DateTime      @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
}

/// Customer quotation (money layer). Numbers are per-company unique (e.g. Q-0001).
model Quotation {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String?
  /** Snapshot / override when not using a lead or for PDF display. */
  customerName     String?
  customerPhone    String?
  quotationNumber  String
  status           String
  totalAmount      Float
  items            Json
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@unique([companyId, quotationNumber])
  @@index([companyId])
  @@index([leadId])
  @@index([status])
}

/// Invoice linked optionally to quotation + lead.
model Invoice {
  id            String    @id @default(cuid())
  companyId     String
  quotationId   String?
  leadId        String?
  invoiceNumber String
  status        String
  totalAmount   Float
  paidAmount    Float     @default(0)
  dueDate       DateTime?
  items         Json
  createdAt     DateTime  @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  quotation   Quotation?       @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  lead        Lead?            @relation(fields: [leadId], references: [id], onDelete: SetNull)
  payments    InvoicePayment[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([quotationId])
  @@index([leadId])
  @@index([status])
}

/// Payment allocated to an invoice (distinct from legacy `Payment` register rows).
model InvoicePayment {
  id        String   @id @default(cuid())
  companyId String
  invoiceId String
  amount    Float
  method    String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([invoiceId])
  @@index([date])
}

model Expense {
  id        String   @id @default(cuid())
  companyId String
  title     String
  amount    Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
}

model ServiceTicket {
  id          String              @id @default(cuid())
  title       String
  description String?             @db.Text
  status      ServiceTicketStatus @default(OPEN)
  companyId   String
  leadId      String?
  assignedTo  String?
  issue       String?
  createdAt   DateTime            @default(now())
  resolvedAt  DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead     Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignee User?   @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([leadId])
  @@index([assignedTo])
}

model SiteVisit {
  id         String   @id @default(cuid())
  companyId  String
  leadId     String
  assignedTo String
  /// SCHEDULED | COMPLETED
  status     String
  report     Json?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User   @relation("SiteVisitAssignee", fields: [assignedTo], references: [id], onDelete: Restrict)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([assignedTo])
  @@index([status])
}

model Approval {
  id        String   @id @default(cuid())
  companyId String
  leadId    String
  /// PENDING | APPROVED | REJECTED
  status    String
  notes     String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([status])
}

/// Company file storage: agreements, approvals, site reports, customer docs.
model Document {
  id        String   @id @default(cuid())
  companyId String
  leadId    String?
  customerId String?
  /// AGREEMENT | APPROVAL | REPORT | OTHER
  type      String
  /// Storage key: `{companyId}/documents/{yyyy}/{mm}/{unique}-{safeName}` (local disk or S3 object key).
  fileUrl   String
  fileName  String
  createdAt DateTime @default(now())
  /// Who uploaded (nullable for legacy rows before audit columns).
  uploadedByUserId String?
  /// `UserRole` at upload time (membership can change later).
  uploadedByRole   String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  uploader User?  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([companyId, type])
  @@index([companyId, uploadedByUserId])
  @@index([leadId])
  @@index([customerId])
}

model LeaveRequest {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  fromDate  DateTime
  toDate    DateTime
  reason    String
  /// PENDING | APPROVED | REJECTED
  status    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([companyId, status])
}

model Attendance {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  date      DateTime
  checkIn   DateTime?
  checkOut  DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, date])
  @@index([companyId])
  @@index([userId])
}

model Salary {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  amount    Float
  month     String

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, month])
  @@index([companyId])
  @@index([userId])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  name      String
  /// Panel | Inverter | Battery | Accessories
  category  String
  unit      String
  minStockLevel Float @default(5)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stocks  Stock[]
  logs    StockLog[]

  @@index([companyId])
  @@index([companyId, category])
}

model Stock {
  id        String   @id @default(cuid())
  companyId String
  productId String
  quantity  Float
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId])
  @@index([companyId])
}

model StockLog {
  id        String   @id @default(cuid())
  companyId String
  productId String
  /// IN | OUT
  type      String
  quantity  Float
  reference String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([productId])
  @@index([companyId, type])
}

model ChannelPartner {
  id              String   @id @default(cuid())
  companyId       String
  name            String
  phone           String
  createdByUserId String
  createdAt       DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator User @relation("PartnerCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  leads   Lead[]
  commissions Commission[]

  @@index([companyId])
  @@index([createdByUserId])
}

model Commission {
  id        String   @id @default(cuid())
  companyId String
  partnerId String
  leadId    String
  amount    Float
  /// DIRECT | REFERRAL
  type      String
  /// PENDING | PAID
  status    String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  partner ChannelPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  lead    Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([companyId, leadId])
  @@index([companyId])
  @@index([partnerId])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  companyId String?
  userId    String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
  @@index([type])
}

/// Internal sales → tech handoff (one row per won lead).
model OnboardingTask {
  id                   String               @id @default(cuid())
  companyId            String
  leadId               String               @unique
  status               OnboardingTaskStatus @default(NEW)
  snapshotCompanyName  String
  snapshotOwnerName    String
  snapshotPhone        String
  snapshotEmail        String?
  snapshotBusinessType String?
  snapshotTeamSize     String?
  snapshotLeadSources  String?              @db.Text
  snapshotProblems     String?              @db.Text
  snapshotRequirements String?              @db.Text
  snapshotPlan         String?
  snapshotWhatsApp     String?
  /** Tier at submit time; drives tech queue priority. */
  leadOnboardingType   LeadOnboardingType?
  techQueuePriority    TechQueuePriority    @default(LOW)
  pipelineStage        TechPipelineStage    @default(RECEIVED)
  /** Extra onboarding fields (team counts, social, enterprise, etc.). */
  formPayload          Json?
  createdByUserId      String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  creator User    @relation("OnboardingTaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([status])
  @@index([companyId, techQueuePriority])
  @@index([companyId, pipelineStage])
}

/// One active manual per {@link UserManualCategory} per company (upsert on upload).
model UserManual {
  id        String             @id @default(cuid())
  companyId String
  category  UserManualCategory
  title     String
  fileUrl   String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, category])
  @@index([companyId])
}

/// Nexa support requests (internal org).
model InternalNexaSupportTicket {
  id               String   @id @default(cuid())
  companyId        String
  leadId           String?
  createdByUserId  String
  /** CALLBACK | MEETING | ISSUE */
  option           String
  /** TECHNICAL | TRAINING | PAYMENT | OTHER */
  category         String
  message          String   @db.Text
  assignedToUserId String?
  status           String   @default("OPEN")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  creator User    @relation("NexaSupportCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([companyId])
  @@index([leadId])
  @@index([companyId, status])
}

/// Timeline entries for internal CRM leads.
model InternalLeadActivity {
  id        String   @id @default(cuid())
  companyId String
  leadId    String
  userId    String?
  action    String
  detail    String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    Lead    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([leadId, createdAt])
}

/// In-app notifications for internal sales / onboarding (BGOS Internal company).
model InternalInAppNotification {
  id        String    @id @default(cuid())
  companyId String
  userId    String
  type      String
  title     String
  body      String    @db.Text
  readAt    DateTime?
  dedupeKey String?
  createdAt DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([companyId, userId, readAt])
}

/// Manager-set daily targets per rep (internal company).
model InternalEmployeeDailyTarget {
  id          String @id @default(cuid())
  companyId   String
  userId      String
  dayKey      String
  targetCalls Int    @default(0)
  targetLeads Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, dayKey])
  @@index([companyId])
}

/// Dynamic sections JSON — rendered by form engine (category + plan tier).
model OnboardingFormTemplate {
  id        String                   @id @default(cuid())
  companyId String
  category  String
  planTier  OnboardingWorkflowPlanTier
  sections  Json
  isActive  Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submissions  OnboardingSubmission[]

  @@unique([companyId, category, planTier])
  @@index([companyId])
  @@index([category, planTier])
}

/// One workflow per linked lead (optional); token access for client fill.
model OnboardingSubmission {
  id                 String                     @id @default(cuid())
  companyId          String
  leadId             String?                    @unique
  templateId         String
  category           String
  planTier           OnboardingWorkflowPlanTier
  filledByUserId     String?
  clientAccessToken  String                     @unique
  status             OnboardingSubmissionStatus @default(DRAFT)
  data               Json                       @default("{}")
  completionPercent  Int                        @default(0)
  assignedTechUserId String?
  deliveryPdfPath    String?
  salesDeliveredAt   DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  company    Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  template   OnboardingFormTemplate  @relation(fields: [templateId], references: [id], onDelete: Restrict)
  lead       Lead?                   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  filledBy   User?                   @relation("OnboardingFilledBy", fields: [filledByUserId], references: [id], onDelete: SetNull)
  techAssignee User?                 @relation("OnboardingTechAssignee", fields: [assignedTechUserId], references: [id], onDelete: SetNull)
  messages   OnboardingMessage[]
  techTask   OnboardingSubmissionTechTask?

  @@index([companyId])
  @@index([status])
  @@index([assignedTechUserId])
}

model OnboardingMessage {
  id           String   @id @default(cuid())
  submissionId String
  senderId     String?
  message      String   @db.Text
  fieldKey     String?
  createdAt    DateTime @default(now())

  submission OnboardingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  sender     User?                @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([submissionId, createdAt])
}

/// Tech-side status mirror (linked 1:1 to submission).
model OnboardingSubmissionTechTask {
  id           String                   @id @default(cuid())
  submissionId String                   @unique
  status       OnboardingTechTaskStatus   @default(NEW)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  submission OnboardingSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([status])
}

// --- Platform Offers & Incentives (BGOS Control — super boss) ---

enum IncentiveAudience {
  SALES
  FRANCHISE
  BOTH
  NICEJOBS
}

enum TargetRoleCategory {
  SALES_EXECUTIVE
  SALES_MANAGER
  MICRO_FRANCHISE
}

enum TargetDurationPreset {
  MONTHLY
  WEEKLY
  CUSTOM
}

enum TargetMetricType {
  LEADS
  ONBOARDINGS
  SUBSCRIPTIONS
  REVENUE
}

enum TargetAssignScope {
  INDIVIDUAL
  DEPARTMENT
  ALL_FRANCHISE_USERS
  ALL_SALES_USERS
}

enum BonusConditionType {
  TARGET_ACHIEVED
  TOP_PERFORMER
  ONBOARDING_COUNT
  REVENUE
}

enum BonusValueType {
  FIXED
  PERCENTAGE
  GIFT
}

enum IncentiveCommissionPlanTier {
  BASIC
  PRO
  ENTERPRISE
  SPECIAL
}

enum IncentiveCampaignLifecycle {
  DRAFT
  ACTIVE
  UPCOMING
  COMPLETED
}

model TargetCampaign {
  id               String               @id @default(cuid())
  title            String
  roleCategory     TargetRoleCategory
  durationPreset   TargetDurationPreset
  metricType       TargetMetricType
  targetNumber     Float
  startDate        DateTime
  endDate          DateTime
  assignScope      TargetAssignScope
  assigneeUserId   String?
  departmentLabel  String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([startDate, endDate])
  @@index([roleCategory])
}

model BonusCampaign {
  id                String                      @id @default(cuid())
  title             String
  eligibleAudience  IncentiveAudience
  conditionType     BonusConditionType
  bonusType         BonusValueType
  bonusValue        Float?
  notes             String?                     @db.Text
  validMonth        String
  poolAmount        Float?
  lifecycle         IncentiveCampaignLifecycle  @default(ACTIVE)
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([validMonth])
  @@index([eligibleAudience])
}

model MegaPrizeCampaign {
  id                 String                      @id @default(cuid())
  name               String
  audience           IncentiveAudience
  eligibilityRules   String                      @db.Text
  prizeDescription   String                      @db.Text
  winnerRule         String                      @db.Text
  startDate          DateTime
  endDate            DateTime
  lifecycle          IncentiveCampaignLifecycle  @default(ACTIVE)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([startDate, endDate])
}

model CommissionRule {
  id                 String                      @id @default(cuid())
  planName           String
  planTier           IncentiveCommissionPlanTier
  commissionType     String
  value              Float
  recurring          Boolean                     @default(true)
  instantSaleBonus   Float                     @default(0)
  isActive           Boolean                     @default(true)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([planTier, isActive])
}

model OfferAnnouncement {
  id         String             @id @default(cuid())
  title      String
  body       String             @db.Text
  audience   IncentiveAudience  @default(BOTH)
  startsAt   DateTime?
  endsAt     DateTime?
  isActive   Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([audience, isActive])
}
